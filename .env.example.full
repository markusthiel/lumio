# =============================================================================
# Lumio — Vollständige Environment-Konfiguration
# =============================================================================
# Diese Datei dokumentiert ALLE verfügbaren Variablen mit Erklärung.
#
# Für den Quick-Start reicht die schlanke `.env.example`. Erst hierher
# wechseln wenn du Custom-Storage, Billing, ML-Features oder andere
# Sonderfälle brauchst.
#
# WICHTIG: niemals .env in git committen.
# =============================================================================

# -----------------------------------------------------------------------------
# Deployment Mode
# -----------------------------------------------------------------------------
# single  = ein Studio, Multi-Tenant deaktiviert. Empfohlen für Self-Hosting.
# multi   = SaaS-Mode: mehrere Tenants auf einer Instanz.
#           Siehe docs/SAAS_MODE.md für Setup mit Stripe.
DEPLOYMENT_MODE=single

# -----------------------------------------------------------------------------
# Public Endpoint
# -----------------------------------------------------------------------------
# DAS ist die EINE App-Adresse, unter der Lumio von außen erreichbar ist.
# Caddy hört darauf, alle anderen URLs werden daraus abgeleitet.
#
# Beispiele:
#   LUMIO_HOST=                              → kein spezifischer Haupt-Block.
#                                              Catch-All bedient alles auf Port 80.
#                                              Empfohlen für lokales Dev.
#   LUMIO_HOST=galerien.example.com          → eigener Block, automatisches
#                                              Let's-Encrypt-HTTPS.
#   LUMIO_HOST=http://galerien.example.com   → nur HTTP, kein Cert (hinter
#                                              externem Reverse-Proxy).
#
# WICHTIG: NICHT `:80` als Default setzen wenn Custom-Domains aktiviert
# werden sollen — das kollidiert mit dem http://-Catch-All-Block.
LUMIO_HOST=

# PUBLIC_URL wird in E-Mails, Galerie-Share-Links und für CORS verwendet.
# Muss zur LUMIO_HOST-Konfiguration passen.
PUBLIC_URL=http://localhost

# Für Multi-Tenant mit Subdomains pro Tenant.
# Siehe docs/WILDCARD.md für Wildcard-Cert-Setup via acme-dns.
#   LUMIO_WILDCARD_HOST=*.galerien.example.com
LUMIO_WILDCARD_HOST=127.0.0.1:9

# Basis-Domain für Subdomain-Tenant-Resolution. Wird vom Backend
# verwendet um <slug>.<DOMAIN_BASE>-Hosts dem richtigen Tenant
# zuzuordnen. Im Studio wird daraus die Anzeige "deine Studio-URL
# ist https://<slug>.<DOMAIN_BASE>" generiert.
#
# Nur im Multi-Mode relevant. Im Single-Mode auskommentiert lassen.
# Beispiel:
#   LUMIO_DOMAIN_BASE=galerien.example.com
# LUMIO_DOMAIN_BASE=

# -----------------------------------------------------------------------------
# S3 / MinIO Public Endpoint
# -----------------------------------------------------------------------------
# Browser laden Bilder/Logos direkt von S3 (über presigned URLs). Dafür
# braucht MinIO einen Hostname, den der Browser erreichen kann — der interne
# Docker-Container-Name 'minio' funktioniert nicht.
#
# Bei externem S3 ist das einfach der S3-Endpoint. Bei MinIO im Compose
# muss Caddy als Reverse-Proxy davor.
#
# Beispiele:
#   LUMIO_S3_HOST=:81                                   → lokal: localhost:81
#   LUMIO_S3_HOST=s3.galerien.example.com               → eigene Subdomain, Auto-HTTPS
#   LUMIO_S3_HOST=http://s3.galerien.example.com        → HTTP hinter externem Proxy
LUMIO_S3_HOST=:81

# Browser-Adresse für Bild-URLs. Bei Hetzner/R2/B2 = direkt der Provider-Endpoint.
# Bei MinIO = die LUMIO_S3_HOST-Adresse von oben.
S3_PUBLIC_URL=

# -----------------------------------------------------------------------------
# Host-Ports (Mapping vom Container nach außen)
# -----------------------------------------------------------------------------
# Anpassen, wenn die Default-Ports auf dem Host schon belegt sind. Caddy ist
# der einzige Container, der wirklich öffentlich erreichbar sein muss.
# FRONTEND und API werden auf 127.0.0.1 gebunden (nur lokal zum Debuggen).
CADDY_HTTP_PORT=80
CADDY_HTTPS_PORT=443
FRONTEND_PORT=3000
API_PORT=3001
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# -----------------------------------------------------------------------------
# Database (Postgres)
# -----------------------------------------------------------------------------
POSTGRES_DB=lumio
POSTGRES_USER=lumio
POSTGRES_PASSWORD=CHANGEME_use_openssl_rand_base64_24
# Wird automatisch aus den obigen drei Werten gebaut. Manuelles Überschreiben:
# DATABASE_URL=postgres://lumio:CHANGEME@postgres:5432/lumio

# -----------------------------------------------------------------------------
# Redis (Queue + Cache + Sessions)
# -----------------------------------------------------------------------------
REDIS_URL=redis://redis:6379

# -----------------------------------------------------------------------------
# Object Storage (S3-kompatibel)
# -----------------------------------------------------------------------------
# Mögliche Werte für STORAGE_PROVIDER:
#   minio       = lokales MinIO (Default für Self-Hosting)
#   s3          = AWS S3
#   r2          = Cloudflare R2
#   b2          = Backblaze B2
#   wasabi      = Wasabi
#   custom      = beliebiges S3-kompatibles Backend (z.B. Hetzner)
#
# Konkrete .env-Beispiele pro Provider: siehe docs/STORAGE.md
STORAGE_PROVIDER=minio

# Endpoint (interner Server-zu-S3-Pfad):
#   - MinIO lokal:   http://minio:9000
#   - AWS S3:        https://s3.<region>.amazonaws.com
#   - Cloudflare R2: https://<account_id>.r2.cloudflarestorage.com
#   - Backblaze B2:  https://s3.<region>.backblazeb2.com
#   - Hetzner:       https://fsn1.your-objectstorage.com
S3_ENDPOINT=http://minio:9000

# Region: bei MinIO egal (us-east-1 als Konvention).
# Bei externem S3 die korrekte Region (Hetzner: fsn1, nbg1, hel1)
S3_REGION=us-east-1

S3_BUCKET=lumio
S3_ACCESS_KEY=CHANGEME_random_string
S3_SECRET_KEY=CHANGEME_random_string

# Path-Style: true für MinIO und die meisten S3-Kompatiblen. AWS und R2: false.
S3_FORCE_PATH_STYLE=true

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
# 32+ zufällige Bytes pro Wert. Generieren: openssl rand -base64 32
JWT_SECRET=CHANGEME_at_least_32_random_chars
SESSION_SECRET=CHANGEME_at_least_32_random_chars
# Argon2-Memory in KiB (Empfehlung: 19456 = 19 MiB)
ARGON2_MEMORY_KIB=19456

# -----------------------------------------------------------------------------
# Mail (Notifications, Einladungen, Passwort-Reset, Galerie-Einladungen)
# -----------------------------------------------------------------------------
# Wenn SMTP_HOST leer ist, läuft Mail-Service im No-Op-Modus (loggt nur,
# schickt nichts). Heißt: "Einladung senden" passiert silent — der Studio-
# User sieht "gesendet", beim Kunden kommt nichts an. Vor Production
# unbedingt konfigurieren!
#
# DACH-Empfehlungen:
#   - Brevo (ehem. Sendinblue): smtp-relay.brevo.com, 300 Mails/Tag gratis
#   - Mailgun EU: smtp.eu.mailgun.org
#   - Postmark: smtp.postmarkapp.com (Premium, hohe Deliverability)
#   - Eigener Postfix: mail.example.com
#
# Wichtig: SMTP_FROM muss ein domain-verifiziertes Absender-Postfach sein,
# sonst landet die Mail beim Endkunden im Spam. SPF + DKIM + DMARC für die
# Absender-Domain einrichten!
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="Lumio <noreply@example.com>"
SMTP_SECURE=false

# -----------------------------------------------------------------------------
# Limits & Upload-Konfiguration
# -----------------------------------------------------------------------------
# Max Größe eines einzelnen Files in MiB (RAW kann groß werden!)
MAX_FILE_SIZE_MIB=2048
# Max parallele Worker-Jobs pro Worker-Container
WORKER_CONCURRENCY=4
# Chunk-Größe für Multipart-Uploads (S3 Minimum: 5 MiB)
UPLOAD_CHUNK_SIZE_MIB=8

# -----------------------------------------------------------------------------
# Billing (Multi-Mode, SaaS)
# -----------------------------------------------------------------------------
# Aktiviert das Abrechnungsmodul. Bei false: alle Features für alle Tenants
# unbegrenzt verfügbar (typisch für Self-Hosting mit DEPLOYMENT_MODE=single).
#
# Komplettes Setup mit Stripe: siehe docs/SAAS_MODE.md
BILLING_ENABLED=false
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
BILLING_CURRENCY=EUR

# -----------------------------------------------------------------------------
# KI-Auto-Tagging (CLIP)
# -----------------------------------------------------------------------------
# Standardmäßig aus. Aktivieren über docker-compose.ml.yml (siehe docs/ML.md).
# Worker entscheidet automatisch ob CUDA verfügbar ist (mit docker-compose.gpu.yml)
# und nutzt dann GPU für 15x schnellere Inferenz.
#
# LUMIO_CLIP_ENABLED=1
# LUMIO_CLIP_MODEL=ViT-B-32           # Default. Alternativen: ViT-L-14, ViT-B-16
# LUMIO_CLIP_PRETRAINED=openai        # Alternative: laion2b_s34b_b79k
# LUMIO_CLIP_THRESHOLD=0.08           # 0..1, höher = weniger aber sicherere Tags

# -----------------------------------------------------------------------------
# Hardware-Encoder (für Video-Transcoding)
# -----------------------------------------------------------------------------
# Standard: auto (NVENC wenn GPU da, sonst libx264).
# Mit docker-compose.gpu.yml fest auf nvenc gesetzt.
# LUMIO_HW_ENCODER=auto

# -----------------------------------------------------------------------------
# Feature-Flags
# -----------------------------------------------------------------------------
# Öffentliche Galerien ohne Passwort erlauben?
FEATURE_PUBLIC_GALLERIES=true
# Auto-Tagging in der Studio-UI sichtbar machen?
FEATURE_AI_TAGGING=false
# Webhooks für Studio-Events (Gallery-Erstellung, Upload, etc.)
FEATURE_WEBHOOKS=false

# -----------------------------------------------------------------------------
# Observability
# -----------------------------------------------------------------------------
LOG_LEVEL=info
# SENTRY_DSN=

# -----------------------------------------------------------------------------
# acme-dns (nur wenn Wildcard-Zertifikate gebraucht werden)
# -----------------------------------------------------------------------------
# Externe IP an die acme-dns gebunden wird (Port 53 UDP+TCP). NICHT auf
# 0.0.0.0 binden — kollidiert mit systemd-resolved auf 127.0.0.53:53.
# Auf der echten Server-IP binden, dann läuft beides parallel.
#
# Beispiel:
# ACME_DNS_BIND_IP=167.233.25.29

# -----------------------------------------------------------------------------
# Marketing-Site Integration (nur relevant für SaaS-Mode)
# -----------------------------------------------------------------------------
# Lumio-API-Endpoint für den /api/signup-Proxy in lumio-cloud-de
# LUMIO_API_BASE=http://lumio_api:3001
# Lead-Notifications Empfänger
# LEAD_ADMIN_EMAIL=
