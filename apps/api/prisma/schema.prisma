// =============================================================================
// Lumio — Prisma Schema
// =============================================================================
// Vollständiges Datenmodell. Migrationen werden mit `npm run prisma:migrate`
// erzeugt und im Container mit `npm run prisma:deploy` ausgerollt.

generator client {
  provider      = "prisma-client-js"
  // native = der Host, auf dem prisma generate gerade läuft (Dev-Maschine).
  // linux-musl-openssl-3.0.x = die Production-Container (node:20-alpine
  // bringt OpenSSL 3 via 'apk add openssl3' mit; siehe Dockerfile).
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// -----------------------------------------------------------------------------
// Multi-Tenancy
// -----------------------------------------------------------------------------
// Im Modus DEPLOYMENT_MODE=single existiert genau EIN Tenant, der automatisch
// beim ersten Start angelegt wird. Im multi-Modus können beliebig viele
// Tenants existieren — z.B. für SaaS-Anbieter.

model Tenant {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug        String   @unique
  // Interner Verwaltungsname — sichtbar fuer Super-Admin, Audit-Logs
  // und Studio-Owner als 'echter Name'. Wird auch als Fallback fuer
  // displayName genutzt wenn der Owner keinen oeffentlichen Namen
  // gesetzt hat.
  name        String
  // Oeffentlicher Anzeigename, vom Owner selbst editierbar in
  // /studio/settings. Sichtbar auf der Login-Seite, in allen Mails,
  // im Welcome-Flow und im Email-Change-Banner. Wenn null, faellt
  // alles auf 'name' zurueck. Trennung ermoeglicht Tenants mit
  // separater Aussenwirkung (z.B. interner Name 'Samuel Rojahn',
  // oeffentlich 'Samuel & Chiara Photography').
  displayName String?
  status      String   @default("active") // active | suspended | archived
  customDomain String? @unique

  // Timestamp wann der Tenant archiviert wurde. Wird beim Archive-
  // Endpoint gesetzt, beim Unsuspend NICHT zurückgesetzt (archive ist
  // einseitig — Unsuspend funktioniert nur aus 'suspended', nicht aus
  // 'archived'). Hard-Delete prüft archivedAt + 30 Tage als Karenz
  // gegen versehentliches sofortiges Wegwerfen.
  archivedAt DateTime?

  // Pre-Archive-Warnung. Wenn der Super-Admin eine Archivierung im
  // Voraus plant, setzt er diesen Timestamp. Studio-Banner warnt den
  // Tenant ab dann mit Countdown. Beim erreichten Stichtag erinnert
  // der Sweeper den Super-Admin (via Audit-Log + Mail), archiviert
  // aber NICHT automatisch — Super-Admin muss manuell klicken.
  archiveScheduledAt DateTime?

  // Beim Setzen eines archiveScheduledAt verschicken wir eine Initial-
  // Mail an alle Owner sowie eine Reminder-Mail 7 Tage vor Stichtag.
  // Wir tracken, welche schon raus sind, damit der Sweeper die Reminder-
  // Mail nicht mehrfach schickt.
  archiveNoticeMailedAt   DateTime?  // Initial-Notice (beim Setzen)
  archiveReminderMailedAt DateTime?  // 7-Tage-Reminder vom Sweeper
  
  // Branding auf Tenant-Ebene (kann pro Galerie überschrieben werden)
  brandingId  String?  @db.Uuid
  branding    Branding? @relation("TenantBranding", fields: [brandingId], references: [id])

  // ---------------------------------------------------------------------------
  // Erscheinungsbild fuer Studio-Backend, Login-Seite und E-Mails.
  // Tenant-weit und bewusst ENTKOPPELT vom Galerie-Branding (das es
  // mehrfach geben kann) — Studio/Login/Mails gibt es je nur einmal.
  // Asset-Felder sind S3-Keys (Schema t/<tenantId>/appearance/<name>)
  // und werden beim Ausliefern signiert. Farben sind #hex; null faellt
  // jeweils auf den eingebauten Standard zurueck (Amber-Akzent, Dark).
  // ---------------------------------------------------------------------------
  studioLogoKey      String?  // Logo in der Sidebar (fuer dunklen Grund)
  studioLogoLightKey String?  // helle Variante (bei hellem Grundton)
  studioAccentColor  String?
  studioTheme        String?  @default("dark") // "dark" | "light"
  loginLogoKey       String?
  loginBackgroundKey String?
  loginGreeting      String?
  loginAccentColor   String?
  loginLayout        String?  @default("centered") // minimal|splash|side_by_side|centered
  // Optionale Farbfläche über dem Login-Hintergrundbild (RGBA-Hex wie
  // "#00000066", alpha = Transparenz). Null = layout-abhängiger Default.
  loginOverlayColor  String?  @db.VarChar(9)
  // Optionaler Weichzeichner (Glas-Effekt) hinter der Farbfläche, in px.
  // Null/0 = kein Blur. Wirkt nur mit Hintergrundbild.
  loginOverlayBlur   Int?
  emailLogoKey       String?
  // Layout für Studio-gebrandete Mails (an Endkunden), zwei Achsen:
  //   mailLogoPosition: left | right | center | footer (Logo-Platzierung)
  //   mailHeaderStyle:  line  | banner               (Kopf-Optik)
  mailLogoPosition   String?  @default("left")
  mailHeaderStyle    String?  @default("line")
  
  // Watermark-Konfiguration (siehe docs/KONZEPT.md §9)
  // Wenn watermarkImageKey gesetzt: PNG aus S3 wird als Overlay verwendet.
  // Sonst: watermarkText als wiederholtes Text-Pattern (Default: tenant.name).
  watermarkImageKey String?
  watermarkText     String?

  // Pro-File Upload-Limit in MiB. Null = ENV-Default (MAX_FILE_SIZE_MIB)
  // wird benutzt. Wenn gesetzt, wird beim Upload-Init gegen diesen Wert
  // validiert; aber NIE höher als MAX_UPLOAD_HARD_CAP_MIB (ENV-Schutz
  // gegen Misskonfiguration und SaaS-Missbrauch). Der Wert greift
  // sowohl für Studio-Uploads als auch für Uploads via UploadLink
  // (Upload-Link kann nur darunter sein, nie darüber).
  maxUploadMib Int?
  
  // Billing (siehe BillingSubscription)
  subscription BillingSubscription?
  
  users       User[]
  galleries   Gallery[]
  brandings   Branding[] @relation("TenantBrandings")
  templates   GalleryTemplate[] @relation("TenantTemplates")
  events      Event[]
  webhooks    Webhook[]
  tags        Tag[]
  smartCollections SmartCollection[]
  exports     TenantExport[]
  notes       TenantNote[]
  featureFlags TenantFeatureFlag[]

  // Print-Shop (alle optional — Tabellen bleiben leer wenn Feature-Flag aus)
  printShopConfig    TenantPrintShopConfig?
  printStripeConnect TenantStripeConnect?
  printProviders     TenantPrintProvider[]
  printProducts      PrintProduct[]
  shippingMethods    ShippingMethod[]
  printOrders        PrintOrder[]
  // Stripe-Customer-ID: lifetime-stabil pro Tenant. Wir setzen sie
  // beim ersten Checkout-Session-Create und nutzen sie wieder bei
  // Plan-Wechseln, Storage-Pack-Käufen, Customer-Portal-Calls.
  // Wenn Tenant gelöscht wird: Stripe-Customer wird NICHT automatisch
  // gelöscht (Audit-Trail bleibt im Stripe-Dashboard). Manuell im
  // Stripe-Dashboard archivieren falls gewünscht.
  stripeCustomerId String?  @unique

  // ---------------------------------------------------------------------------
  // AVV / Auftragsverarbeitungsvertrag (Art. 28 DSGVO)
  //
  // Stammdaten des Verantwortlichen (= dieses Tenants als Studio-Kunde).
  // Werden im Studio erfasst und in den generierten AVV eingesetzt.
  // Pflichtfelder fuer einen vollstaendigen AVV: legalName + Anschrift.
  // ---------------------------------------------------------------------------
  legalName       String?  // vollstaendige Firmierung / Name des Verantwortlichen
  legalStreet     String?  // Strasse + Hausnummer
  legalPostalCode String?
  legalCity       String?
  legalCountry    String?  // Default-Anzeige "Deutschland", wenn null
  vatId           String?  // USt-IdNr. (optional)

  dpaAcceptances  DpaAcceptance[]

  // ---------------------------------------------------------------------------
  // Self-Service-Tenant-Loeschung (DSGVO Art. 17)
  //
  // Owner kann sein Studio selbst loeschen — Flow:
  //   1. POST /account/delete-request → setzt diese drei Felder + 
  //      status='pending_deletion'. Stripe-Subscription wird sofort
  //      gecancelled. Login bleibt moeglich, aber Schreiboperationen
  //      sind gesperrt (read-only-Plugin pruefte status).
  //   2. Bis selfDeletionScheduledFor kann der Owner ueber
  //      POST /account/delete-request/cancel die Loeschung zuruecknehmen.
  //      Stripe-Subscription muss er dann ggf. neu starten.
  //   3. Wenn selfDeletionScheduledFor erreicht: Sweeper macht
  //      Hard-Delete (S3-Files + DB-Cascade) und schickt finale
  //      Bestaetigung an die Owner-Email (gemerkt im Audit-Log).
  //
  // Trennung zu archivedAt/archiveScheduledAt (Super-Admin-Pfad):
  // Self-Service ist OWNER-getrieben mit 60 Tagen Karenz und HARD-
  // DELETE am Ende. Super-Admin-Archive ist Compliance/Strafe-Pfad
  // mit Soft-Archive (keep data forever) und manuellem Hard-Delete.
  selfDeletionRequestedAt   DateTime?
  selfDeletionRequestedById String?   @db.Uuid
  selfDeletionScheduledFor  DateTime?
  // Reminder-Mail 7 Tage vor Hard-Delete — Sweeper-Sperre wie bei
  // archiveReminderMailedAt damit nicht mehrfach gemailed wird.
  selfDeletionReminderMailedAt DateTime?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([slug])
  @@index([selfDeletionScheduledFor])
  @@map("tenants")
}

// -----------------------------------------------------------------------------
// Auth: Studio-User
// -----------------------------------------------------------------------------
model User {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String   @db.Uuid
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  email        String   @db.Citext
  passwordHash String
  name         String?
  role         String   @default("member") // owner | admin | member
  status       String   @default("active") // active | invited | disabled
  
  // 2FA
  totpSecret   String?
  totpEnabled  Boolean  @default(false)
  // Einmalige Backup-Codes (sha256-gehasht, komma-separiert). Werden beim
  // Verbrauch aus dem String entfernt.
  totpBackupCodes String?
  
  galleries    Gallery[]
  sessions     Session[]
  webauthnCredentials WebauthnCredential[]
  apiTokens    ApiToken[]
  passwordResetTokens PasswordResetToken[]
  smartCollections SmartCollection[] @relation("SmartCollectionOwner")
  galleryCollaborations GalleryCollaborator[] @relation("GalleryCollaboratorUser")

  /// Wenn true: dieser User erhaelt keine Broadcast-Mails mehr.
  /// System-Mails (Password-Reset, Galerie-Einladungen, Lifecycle-
  /// Mails) gehen UNABHAENGIG raus — die sind kein Marketing.
  broadcastOptOut Boolean @default(false)
  /// Stabiles Token fuer Unsubscribe-Links. Wird lazy beim ersten
  /// Broadcast-Versand generiert. Frei rotierbar.
  broadcastOptOutToken String? @unique

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  lastLoginAt  DateTime?
  
  @@unique([tenantId, email])
  @@index([email])
  @@map("users")
}

model ApiToken {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String   @db.Uuid
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  name        String   // "Lightroom @ Studio-Mac"
  tokenHash   String   @unique  // sha256 hex
  scopes      String   @default("[\"plugin\"]")  // JSON-Array
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  createdAt   DateTime @default(now())

  @@index([userId])
  @@map("api_tokens")
}

model WebauthnCredential {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId        String   @db.Uuid
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  credentialId  String   @unique
  publicKey     Bytes
  signCount     BigInt   @default(0)
  // transports als JSON-Array gespeichert ('usb','nfc','ble','internal','hybrid').
  // Hilft dem Browser beim Authentifizieren, das richtige Device anzufragen.
  transports    String?
  label         String   // "Mein MacBook", "YubiKey #1" — vom User vergeben

  createdAt     DateTime @default(now())
  lastUsedAt    DateTime?

  @@index([userId])
  @@map("webauthn_credentials")
}

model Session {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  tokenHash String   @unique
  ipAddress String?
  userAgent String?

  /// Wenn gesetzt: diese Session wurde durch einen Super-Admin als
  /// Impersonate-Login erzeugt. Bedeutet:
  ///   - kuerzere TTL (1h statt 30d)
  ///   - Audit-Log bei Schreibaktionen taggt sich super-admin mit
  ///   - Studio-Frontend zeigt einen Banner
  /// Wird NIE auf einer regulaeren User-Login-Session gesetzt.
  impersonatedBySuperAdminId String? @db.Uuid
  
  expiresAt DateTime
  createdAt DateTime @default(now())
  
  @@index([userId])
  @@map("sessions")
}

// -----------------------------------------------------------------------------
// Branding (Whitelabel)
// -----------------------------------------------------------------------------
model Branding {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId      String   @db.Uuid
  tenant        Tenant   @relation("TenantBrandings", fields: [tenantId], references: [id], onDelete: Cascade)
  
  name          String   // interne Bezeichnung, z.B. "Standard", "Hochzeit-Style"
  logoUrl       String?
  // Helle/inverse Logo-Variante fuer dunkle Hintergruende (Studio-Dark-
  // UI, Login-Hero mit Overlay). Wenn null, fallen die dunklen Render-
  // Flaechen auf logoUrl zurueck — bei schwarzen Logos kann das zu
  // schwer lesbarem Ergebnis fuehren, deshalb empfehlen wir im Editor
  // auch eine helle Version hochzuladen.
  logoLightUrl  String?
  faviconUrl    String?
  primaryColor  String   @default("#0f172a")
  accentColor   String   @default("#f59e0b")
  fontFamily    String   @default("Inter")
  introText     String?
  footerText    String?
  customCss     String?

  galleries     Gallery[]
  tenantsAsDefault Tenant[] @relation("TenantBranding")
  templates     GalleryTemplate[] @relation("BrandingForTemplates")
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  @@index([tenantId])
  @@map("brandings")
}

// -----------------------------------------------------------------------------
// Galerie-Templates
// -----------------------------------------------------------------------------
// Wiederverwendbare Settings-Bundles, die beim Anlegen einer neuen Galerie
// als Defaults übernommen werden. Beispiel: "Hochzeit" = collaboration-Mode,
// Download aus, Watermark an, Kommentare an, 30 Tage Frist, Branding-X.
//
// Nach dem Anlegen lassen sich alle übernommenen Settings pro Galerie noch
// individuell ändern — das Template ist nur ein Initial-State, kein Lock.
model GalleryTemplate {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId          String   @db.Uuid
  tenant            Tenant   @relation("TenantTemplates", fields: [tenantId], references: [id], onDelete: Cascade)
  
  name              String   // interne Bezeichnung, z.B. "Hochzeit", "Newborn"
  description       String?  // optionale Erklärung für andere Studio-User
  
  // Galerie-Settings
  mode              String   @default("collaboration")  // collaboration | presentation
  downloadEnabled   Boolean  @default(true)
  watermarkEnabled  Boolean  @default(false)
  commentsEnabled   Boolean  @default(true)
  ratingsEnabled    Boolean  @default(true)
  
  // Standard-Ablaufzeit in Tagen ab Erstellung — null = unbegrenzt
  defaultExpiryDays Int?
  
  // Default-Beschreibung für neue Galerien (kann pro Galerie überschrieben)
  defaultDescription String?
  
  // Welches Branding-Profil — null bedeutet "Tenant-Default"
  brandingId        String?  @db.Uuid
  branding          Branding? @relation("BrandingForTemplates", fields: [brandingId], references: [id], onDelete: SetNull)
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  @@index([tenantId])
  @@map("gallery_templates")
}

// -----------------------------------------------------------------------------
// Galerie
// -----------------------------------------------------------------------------
model Gallery {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId        String   @db.Uuid
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  ownerId         String   @db.Uuid
  owner           User     @relation(fields: [ownerId], references: [id])
  
  brandingId      String?  @db.Uuid
  branding        Branding? @relation(fields: [brandingId], references: [id])
  
  slug            String   @unique // kryptografisch zufällig, z.B. 12 chars
  title           String
  description     String?
  
  mode            String   @default("collaboration") // collaboration | presentation
  status          String   @default("draft")          // draft | live | archived
  
  // Zugangskontrolle
  passwordHash    String?
  expiresAt       DateTime?
  
  // Feature-Toggles pro Galerie
  downloadEnabled Boolean  @default(true)
  // Zusatz zu downloadEnabled: wenn true, dürfen Kunden auch die Originale
  // herunterladen (sonst nur die Web-Renditions ~2560px webp). Default true
  // damit existierende Galerien unverändert weiterlaufen — der neue Toggle
  // im Studio gibt Photographen die explizite Wahl "nur Web ausliefern".
  downloadOriginalsEnabled Boolean @default(true)
  watermarkEnabled Boolean @default(false)
  commentsEnabled Boolean  @default(true)
  ratingsEnabled  Boolean  @default(true)
  // Wenn true: Kunde sieht die FileTags in seiner Galerie und kann
  // damit filtern + Tag-gefilterte ZIPs herunterladen. Default false
  // damit Tag-Vorschlaege/-Korrekturen nicht versehentlich Kunden-
  // sichtbar werden. Studio aktiviert pro Galerie wenn gewuenscht.
  customerTagFilterEnabled Boolean @default(false)
  selectionLimit  Int?     // max Anzahl Auswahl für Kunde
  emailRequired   Boolean  @default(false) // Kunde muss E-Mail eingeben
  
  // Cover-Bild
  coverFileId     String?  @db.Uuid
  
  // ---------------------------------------------------------------------------
  // Header-Customization pro Galerie
  // ---------------------------------------------------------------------------
  // Hero-Bild im Galerie-Header: entweder ein Bild AUS der Galerie
  // (heroFileId zeigt auf eine File-Row) ODER ein separater Upload
  // (heroUrl ist ein S3-Storage-Key, kein Public-URL). Beide gleichzeitig
  // ist nicht vorgesehen — UI lässt nur eines setzen, aber das Schema
  // verbietet es nicht hart, weil das Studio später beide haben dürfen
  // könnte (z.B. "Fallback wenn File gelöscht").
  heroFileId       String?  @db.Uuid
  heroUrl          String?  // S3-Key oder absolute URL (CDN), nullable
  
  // Optional Overlay-Farbe über dem Hero. Hex-RGBA-String wie "#00000066"
  // (alpha = 0x66 ~ 40%). Wenn null, kein Overlay. Wird im Frontend als
  // CSS background-color über das Hero-Bild gelegt.
  heroOverlayColor String?  @db.VarChar(9)
  // Optionaler Weichzeichner (Glas-Effekt) hinter dem Hero-Overlay, in px.
  // Null/0 = kein Blur. Analog zum Login-Overlay (loginOverlayBlur).
  heroOverlayBlur  Int?
  
  // Hintergrund-Farbe wenn KEIN Hero-Bild gesetzt ist. Hex-String wie
  // "#0f172a". Default null → Frontend nutzt globale Surface-Farbe.
  heroBackgroundColor String? @db.VarChar(7)
  
  // Galerie-spezifisches Logo (Event-Logo, Monogramm, ...). S3-Key oder
  // absolute URL. Wird klein im Header über/neben dem Titel angezeigt.
  // UNABHÄNGIG vom Branding-Logo (das ist Studio-weit) — beide können
  // gleichzeitig vorhanden sein.
  eventLogoUrl     String?
  
  // Reich formatierter Welcome-Text. Markdown — gerendert im Customer-
  // Header unter Titel/Description. Wenn null, wird nur description
  // angezeigt (Plain-Text). Description bleibt für den Galerie-Listen-
  // Auftritt (Studio, Mail-Vorschau) erhalten — markdown ist NUR für
  // den Customer-View.
  welcomeMarkdown  String?
  
  // Hero-Layout-Variante. Bestimmt, wie der Customer-Header gerendert wird:
  //   "minimal"      — aktuelle Default-Ansicht, Text auf Backdrop (mit oder
  //                    ohne Hero-Bild)
  //   "splash"       — Vollbild-Hero, Titel zentriert, dezenter Scroll-Hint
  //   "side_by_side" — Editorial-Layout, Text links + Bild rechts
  //   "centered"     — Magazin-Style, Logo+Titel zentriert, Hero darunter klein
  // Default "minimal" → existierende Galerien sehen identisch aus.
  heroLayout       String   @default("minimal")
  
  // Grid-Layout-Variante für das File-Grid auf der Customer-Seite:
  //   "equal"     — alle Tiles exakt gleich (Quadrate). Default.
  //   "justified" — Reihen-basiert, Bilder einer Reihe gleich hoch
  //                 (flex-wrap + flex-grow Trick, kein JS-Layout).
  //
  // Historische Werte: "masonry" existierte als CSS-columns-Layout,
  // wurde aber entfernt weil es die Lese-Reihenfolge gegenüber der
  // Lightbox-Navigation kaputtmachte (Bilder spaltenweise gestapelt
  // statt zeilenweise). Die Migration setzt vorhandene
  // gridLayout='masonry' auf 'equal' um.
  gridLayout       String   @default("equal")
  
  // Slideshow-Übergangseffekt:
  //   "fade"    aktueller Default — Cross-Fade ~600ms zwischen Bildern
  //   "slide"   Bild slidet von rechts rein (350ms ease-out)
  //   "kenburns" langsamer Zoom + Pan auf jedem Bild (Slideshow-Klassiker)
  slideshowTransition String @default("fade")
  
  // Optional Hintergrund-Musik für die Slideshow. S3-Storage-Key
  // (z.B. "t/<tenant>/galleries/<gallery>/audio/bg-<rand>.mp3").
  // Spielt NUR im Slideshow-Modus, nicht im normalen Browse — der
  // Customer hat dort schon eine User-Geste gemacht (Slideshow-Start),
  // damit ist Auto-Play durch Browser-Policies erlaubt.
  // Loopt automatisch, Volume-Default 70 %, im Slideshow-UI per
  // Slider justierbar (clientseitig, nicht persistiert).
  slideshowAudioUrl String?
  
  // Galerie-spezifische Schriftarten — überschreiben die Branding-
  // Schriftart nur für diese Galerie. Beide Felder sind kurze IDs
  // aus einer kuratierten Liste (siehe lib/fonts.ts im Frontend),
  // KEINE freien Strings — das Frontend macht eine Lookup gegen die
  // Liste und ignoriert unbekannte Werte.
  //   fontHeading: für h1/h2 (Galerie-Titel, Markdown-Headings)
  //   fontBody:    für alles andere (Description, Welcome-Body, UI)
  // Beide null → Branding-Default gewinnt.
  fontHeading      String?  @db.VarChar(40)
  fontBody         String?  @db.VarChar(40)
  
  // Galerie-spezifisches Footer-Markdown. Wird am Ende der Customer-
  // Seite unterhalb des File-Grids gerendert. Typischerweise:
  // Dankeschön-Text, Kontaktdaten, Social-Media-Links. Wenn null wird
  // nur der Tenant-weite Branding-Footer gerendert (falls vorhanden).
  footerMarkdown   String?
  
  // Galerie-spezifische Farben — überschreiben die entsprechenden
  // Werte des Tenant-Brandings nur für diese eine Galerie.
  // - colorBackground: Surface-Canvas (Hauptfläche der Customer-Seite)
  //   Text auf diesem Hintergrund wird automatisch in den passenden
  //   Kontrast (hell oder dunkel) berechnet — kein separates Text-
  //   Color-Feld nötig.
  // - colorAccent: Akzent-Farbe (Buttons, Selection-Marker, Links)
  //   Auch hier wird die "Contrast"-Farbe (Text auf Akzent) automatisch
  //   berechnet.
  // Beide Hex-#RRGGBB.
  colorBackground  String? @db.VarChar(7)
  colorAccent      String? @db.VarChar(7)
  
  // Flexible Einstellungen (Sortierung, Layout, ...)
  settings        Json     @default("{}")
  
  files           File[]
  accessTokens    GalleryAccess[]
  uploadLinks     UploadLink[]
  downloadLogs    DownloadLog[]
  zipDownloads    ZipDownload[]
  tags            GalleryTag[]
  sections        GallerySection[]

  // Print-Shop: aktivierbar pro Galerie. null = uebernimmt
  // TenantPrintShopConfig.enabled. true/false = expliziter Override.
  // Wenn eine Hochzeitsgalerie privat fuer Familie ist, soll der
  // Endkunde keine Bestellungen sehen koennen.
  printShopEnabled Boolean?
  printOrders     PrintOrder[]
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  collaborators   GalleryCollaborator[]
  @@index([tenantId])
  @@index([ownerId])
  @@index([slug])
  @@map("galleries")
}

/// Freigabe einer Galerie für ein Team-Mitglied (granulare Sichtbarkeit).
/// Wer hier eingetragen ist, hat volle Rechte auf die Galerie (sehen,
/// bearbeiten, löschen, weiter freigeben) — siehe lib/gallery-access.ts.
model GalleryCollaborator {
  id          String   @id @default(uuid()) @db.Uuid
  galleryId   String   @db.Uuid
  gallery     Gallery  @relation(fields: [galleryId], references: [id], onDelete: Cascade)
  userId      String   @db.Uuid
  user        User     @relation("GalleryCollaboratorUser", fields: [userId], references: [id], onDelete: Cascade)
  /// Wer die Freigabe erteilt hat (für Audit; bleibt bei User-Löschung null).
  addedById   String?  @db.Uuid
  createdAt   DateTime @default(now())

  @@unique([galleryId, userId])
  @@index([userId])
  @@index([galleryId])
  @@map("gallery_collaborators")
}

// -----------------------------------------------------------------------------
// Galerie-Sections / Kapitel
// -----------------------------------------------------------------------------
// Optionales Gruppierungs-Layer für eine Galerie. Sections sind
// Kapitel wie "Vorbereitung", "Trauung", "Feier" für eine
// Hochzeitsgalerie. Files können einer Section zugeordnet werden;
// Files ohne Section bleiben im Default-Bucket und werden im Customer-
// View oberhalb der Sections gerendert.
//
// Sortierung über sortIndex (kleinster zuerst), nicht alphabetisch —
// das Studio entscheidet die Reihenfolge bewusst (chronologisch
// passend zum Event-Ablauf).
//
// Cover-Bild ist optional. Wenn gesetzt, zeigt der Section-Renderer
// im Customer-View ein größeres Banner mit dem Cover; sonst nur einen
// Titel-Trennbalken.
model GallerySection {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  galleryId   String   @db.Uuid
  gallery     Gallery  @relation(fields: [galleryId], references: [id], onDelete: Cascade)
  
  title       String   @db.VarChar(120)
  // Optional: Beschreibung als Plain-Text-Untertitel (kein Markdown
  // hier — Section-Beschreibungen sind kurz und einzeilig in der
  // Customer-Anzeige; Markdown wäre Overkill).
  description String?  @db.VarChar(400)
  
  // Cover-File: muss zur SELBEN Galerie gehören. Wenn das File
  // gelöscht wird, setzen wir das Cover zurück auf null (SetNull),
  // damit die Section bestehen bleibt.
  coverFileId String?  @db.Uuid
  
  sortIndex   Int      @default(0)
  
  // Smart-Section: wenn autoTagId gesetzt, ist diese Section eine
  // "automatische" — sie sammelt Files via ihrem Tag statt manuell
  // zugewiesen zu werden. Sync ist explizit (POST .../sync) und
  // implizit nach Tag-Aenderungen (Studio + Auto-Tag-Accept).
  //
  // onDelete: SetNull → wenn der Tag geloescht wird, wird die
  // Section zu einer normalen manuellen Section (Files bleiben drin).
  autoTagId   String?  @db.Uuid
  autoTag     Tag?     @relation(fields: [autoTagId], references: [id], onDelete: SetNull)
  
  files       File[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([galleryId, sortIndex])
  @@index([autoTagId])
  @@map("gallery_sections")
}

// -----------------------------------------------------------------------------
// ZIP Downloads (pre-built, gecacht in S3)
// -----------------------------------------------------------------------------
// Wenn ein Kunde "Alle herunterladen" klickt, baut der Worker eine ZIP-Datei
// und cached sie für 7 Tage. Erneute Anfragen geben den fertigen Link zurück.
// Pro Galerie + Auswahl-Set (oder NULL für "alle") ein Eintrag.
model ZipDownload {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  galleryId   String   @db.Uuid
  gallery     Gallery  @relation(fields: [galleryId], references: [id], onDelete: Cascade)
  
  // Wer hat ihn angefordert? Null = öffentlich (alle Files der Galerie).
  // Wenn gesetzt: spezifisch zur Auswahl dieses Access-Tokens.
  accessId    String?  @db.Uuid
  
  // Wenn diese ZIP nur eine Untermenge der Files enthält (z.B. die
  // gepickten), hashen wir die fileId-Liste, um Cache-Hits zu erkennen.
  // NULL = "alle Files der Galerie".
  fileIdsHash String?
  fileCount   Int
  
  // "original" oder "web" — bestimmt, welche Bytes in die ZIP gepackt
  // werden. Default "original" für Rückwärtskompatibilität — der Worker
  // bzw. ältere Einträge ohne explizite Wahl liefern Originals.
  variant     String   @default("original")
  
  status      String   @default("pending") // pending | building | ready | failed
  storageKey  String?  // wenn ready
  sizeBytes   BigInt?
  errorMessage String?
  
  // Wann der Kunde benachrichtigt wurde (Mail). Null = noch nicht.
  notifiedAt  DateTime?
  
  expiresAt   DateTime // 7 Tage nach Erstellung
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([galleryId, expiresAt])
  @@unique([galleryId, accessId, fileIdsHash, variant])
  @@map("zip_downloads")
}

// -----------------------------------------------------------------------------
// Galerie-Zugang (Tokens für Kunden)
// -----------------------------------------------------------------------------
model GalleryAccess {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  galleryId     String   @db.Uuid
  gallery       Gallery  @relation(fields: [galleryId], references: [id], onDelete: Cascade)
  
  token         String   @unique     // kryptografisch zufällig
  label         String   // z.B. "Brautpaar", "Agentur ABC", "Team Sales"
  // Empfaenger fuer Einladungs-Mails. Leeres Array = keine Mail-
  // Adresse hinterlegt, Re-Send nicht moeglich. Mehrere Adressen
  // sind moeglich (Brautpaar = 2 Personen, Familie = mehrere, etc.).
  // citext-Typ wuerde wir gerne nutzen aber Postgres erlaubt das
  // nicht direkt fuer Array-Spalten — die Case-insensitive-Vergleiche
  // machen wir bei Bedarf programmatisch.
  emails        String[] @default([])
  
  // Berechtigungen
  canDownload   Boolean  @default(true)
  canComment    Boolean  @default(true)
  canSelect     Boolean  @default(true)
  canSeeOthers  Boolean  @default(false) // sieht Kommentare/Auswahl anderer Teams?
  
  expiresAt     DateTime?
  lastAccessAt  DateTime?
  accessCount   Int      @default(0)
  
  // Wenn der Kunde explizit "Auswahl abschließen" geklickt hat
  finalizedAt   DateTime?
  
  selections    Selection[]
  comments      Comment[]
  
  createdAt     DateTime @default(now())
  
  @@index([galleryId])
  @@index([token])
  @@map("gallery_access")
}

// -----------------------------------------------------------------------------
// Upload-Links (öffentliche Drag-and-Drop Upload-Endpunkte pro Galerie)
// -----------------------------------------------------------------------------
// Erlaubt es dem Studio-Owner, einen Link zu erstellen den er an Dritte
// teilen kann ("Schick mir die Hochzeitsfotos vom Junggesellenabend").
// Empfänger landen auf einer minimalen Upload-Page (kein Login, ggf.
// Passwort), können Files reinziehen, sehen aber NICHTS von der
// Galerie selbst und auch nicht die Uploads anderer.
//
// Files die über einen UploadLink reinkommen werden mit
// File.uploadedVia='upload_link' und File.publicVisibility='hidden'
// gespeichert: Studio-User sieht sie sofort (mit Badge), Customer-
// Galerie zeigt sie erst nach manueller Freigabe.
model UploadLink {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  galleryId       String   @db.Uuid
  gallery         Gallery  @relation(fields: [galleryId], references: [id], onDelete: Cascade)

  // Kryptografisch zufälliger Token in der URL — analog GalleryAccess.token.
  // 32 Bytes (urlsafe base64 → ~43 Chars). Wird beim Erstellen einmal
  // generiert, nie geupdated.
  token           String   @unique
  label           String   // z.B. "Junggesellenabend Team Müller"

  // Optionales Passwort (bcrypt-Hash). Wenn null: kein Login-Step, der
  // Link allein reicht. Wenn gesetzt: Upload-Page zeigt eine Passwort-
  // Eingabe vor dem Drag-and-Drop.
  passwordHash    String?

  // Aktiv-Schalter — wenn false, gibt der Endpoint 403 zurück und die
  // Upload-Page zeigt "Link deaktiviert". Studio kann jederzeit
  // toggeln ohne den Link löschen zu müssen.
  active          Boolean  @default(true)

  // Limits — alle optional. Wenn null = kein Limit für diese Dimension.
  // Hard-Limit pro File greift IMMER (siehe config.MAX_FILE_SIZE_MIB),
  // diese Limits sind zusätzlich pro Link.
  maxFiles        Int?     // max Anzahl Files über DIESEN Link in Summe
  maxBytesTotal   BigInt?  // max Gesamt-Größe über DIESEN Link
  // Per-File-Limit für DIESEN Link in Bytes. Null = Tenant-Wert
  // erbt sich durch (tenant.maxUploadMib oder ENV-Default). Wenn
  // gesetzt: MUSS ≤ Tenant-Limit sein (Validierung im API). So
  // kann der Studio-User einen Link explizit auf "max 50 MB pro
  // File" setzen, z.B. für Smartphone-Schnappschüsse vom Gast.
  maxFileBytes    BigInt?

  // Ablauf-Datum — nach diesem Zeitpunkt 403. Null = kein Ablauf.
  expiresAt       DateTime?

  // Live-Statistik. Werden bei jedem erfolgreichen Upload aktualisiert.
  uploadCount     Int      @default(0)
  bytesUploaded   BigInt   @default(0)
  lastUploadAt    DateTime?

  // Files die über diesen Link reingekommen sind. SetNull bei Delete,
  // damit alte Files erhalten bleiben aber den Link-Bezug verlieren.
  files           File[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([galleryId])
  @@index([token])
  @@map("upload_links")
}

// -----------------------------------------------------------------------------
// Files & Renditions
// -----------------------------------------------------------------------------
model File {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  galleryId       String   @db.Uuid
  gallery         Gallery  @relation(fields: [galleryId], references: [id], onDelete: Cascade)
  
  originalFilename String
  storageKey      String   // Pfad im S3-Bucket
  mimeType        String
  sizeBytes       BigInt
  sha256          String?
  
  width           Int?
  height          Int?
  durationMs      Int?     // bei Videos
  
  // Kategorisierung
  kind            String   // image | raw | video | other
  
  // EXIF / Metadaten flexibel
  exif            Json?
  takenAt         DateTime?
  
  // Processing-Status
  status          String   @default("uploading") // uploading | processing | ready | failed
  errorMessage    String?
  
  sortIndex       Int      @default(0)
  
  // Hochlade-Quelle: wer hat das File hier reingeholt?
  //   "studio"      → Owner/Mitarbeiter über Studio-UI (Standard)
  //   "upload_link" → Dritte über einen UploadLink (mit Token)
  // Files mit uploadLinkId können vom Studio noch nicht-freigegeben
  // sein (publicVisibility='hidden') — dann sieht der Studio-User
  // sie mit Badge, der Customer aber noch nicht.
  uploadedVia     String   @default("studio") // "studio" | "upload_link"
  uploadLinkId    String?  @db.Uuid
  uploadLink      UploadLink? @relation(fields: [uploadLinkId], references: [id], onDelete: SetNull)

  // Customer-Sichtbarkeit. Bei studio-Uploads default "visible".
  // Bei upload_link default "hidden" — Studio sieht im Studio,
  // Customer-Galerie zeigt aber erst nach 'approve'.
  // "rejected" = Studio hat den Upload aktiv abgelehnt; S3-Objekte
  // wurden gelöscht (kein Thumb mehr, kein Original), DB-Row bleibt
  // für Audit + UI-Anzeige.
  publicVisibility String  @default("visible") // "visible" | "hidden" | "rejected"

  // Reject-Metadaten — gesetzt nur wenn publicVisibility="rejected".
  // Reason ist freitext (max 500), aus Preset-Optionen oder eigener
  // Eingabe. rejectedBy = User-ID des Studio-Owners der abgelehnt hat.
  rejectedAt      DateTime?
  rejectedBy      String?  @db.Uuid
  rejectedReason  String?

  // Optional einer Section/Kapitel zugeordnet. Null = File erscheint
  // im Default-Bucket der Galerie (Pre-Section-Verhalten). Section
  // gehört IMMER zur selben Galerie wie das File — wir prüfen das
  // anwendungsseitig (kein zusammengesetzter FK in Postgres).
  sectionId       String?  @db.Uuid
  section         GallerySection? @relation(fields: [sectionId], references: [id], onDelete: SetNull)
  
  renditions      Rendition[]
  selections      Selection[]
  comments        Comment[]
  downloadLogs    DownloadLog[]
  tags            FileTag[]
  autoTags        FileAutoTag[]
  printOrderItems PrintOrderItem[]
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@index([galleryId, sortIndex])
  @@index([galleryId, status])
  @@index([galleryId, publicVisibility])
  @@index([sha256])
  // Composite-Index fuer die Duplikat-Erkennung pro Galerie: die
  // Query `SELECT ... WHERE galleryId=? GROUP BY sha256 HAVING count>1`
  // landet damit auf einem reinen Index-Scan, ohne Heap-Lookup.
  @@index([galleryId, sha256])
  @@index([sectionId])
  @@index([uploadLinkId])
  @@map("files")
}

model Rendition {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  fileId      String   @db.Uuid
  file        File     @relation(fields: [fileId], references: [id], onDelete: Cascade)
  
  kind        String   // thumb | preview | web | watermarked | download | hls | poster | sprite
  storageKey  String
  format      String   // webp | avif | jpeg | mp4 | m3u8 | ...
  width       Int?
  height      Int?
  sizeBytes   BigInt
  // Rendition-spezifische Metadaten. Schema je nach kind:
  //   sprite: { interval: float, cols: int, rows: int,
  //             tileWidth: int, tileHeight: int, frames: int }
  metadata    Json?
  
  createdAt   DateTime @default(now())
  
  @@unique([fileId, kind])
  @@index([fileId])
  @@map("renditions")
}

// -----------------------------------------------------------------------------
// Proofing: Auswahl, Kommentare, Ratings
// -----------------------------------------------------------------------------
model Selection {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  fileId        String   @db.Uuid
  file          File     @relation(fields: [fileId], references: [id], onDelete: Cascade)
  
  accessId      String   @db.Uuid
  access        GalleryAccess @relation(fields: [accessId], references: [id], onDelete: Cascade)
  
  // Picdrop-Style Color-Tags
  color         String?  // red | yellow | green
  rating        Int?     // 1-5 Sterne
  liked         Boolean  @default(false)
  status        String?  // pick | reject | maybe
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  @@unique([fileId, accessId])
  @@index([fileId])
  @@index([accessId])
  @@map("selections")
}

model Comment {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  fileId        String   @db.Uuid
  file          File     @relation(fields: [fileId], references: [id], onDelete: Cascade)
  
  accessId      String?  @db.Uuid
  access        GalleryAccess? @relation(fields: [accessId], references: [id], onDelete: Cascade)
  
  authorLabel   String   // "Anna (Brautpaar)" oder "Studio"
  authorIsStudio Boolean @default(false)
  
  body          String
  // Scribbles als SVG-Pfad-Daten / Punkte (für Annotationen direkt auf Bild)
  annotation    Json?
  
  parentId      String?  @db.Uuid
  parent        Comment? @relation("CommentThread", fields: [parentId], references: [id], onDelete: Cascade)
  replies       Comment[] @relation("CommentThread")
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  @@index([fileId])
  @@index([accessId])
  @@map("comments")
}

// -----------------------------------------------------------------------------
// Download-Log (Audit)
// -----------------------------------------------------------------------------
model DownloadLog {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  galleryId   String   @db.Uuid
  gallery     Gallery  @relation(fields: [galleryId], references: [id], onDelete: Cascade)
  
  fileId      String?  @db.Uuid
  file        File?    @relation(fields: [fileId], references: [id], onDelete: SetNull)
  
  kind        String   // single | zip | rendition
  ipAddress   String?
  userAgent   String?
  bytes       BigInt?
  
  createdAt   DateTime @default(now())
  
  @@index([galleryId, createdAt])
  @@map("download_logs")
}

// -----------------------------------------------------------------------------
// Generischer Event-Log (Audit)
// -----------------------------------------------------------------------------
model Event {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  // Tenant-Kontext eines Events. Bei Super-Admin-Aktionen ohne Tenant-Bezug
  // (Login/Logout) ist das null; bei Aktionen gegen einen Tenant
  // (suspend/archive/owner-invite) wird der Ziel-Tenant gesetzt — damit
  // bleibt das Audit-Log eines Tenants chronologisch vollständig.
  tenantId    String?  @db.Uuid
  tenant      Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  actorType   String   // user | access | system
  actorId     String?
  action      String   // login | gallery.create | file.delete | share.create | ...
  targetType  String?
  targetId    String?
  payload     Json?
  ipAddress   String?
  
  createdAt   DateTime @default(now())
  
  @@index([tenantId, createdAt])
  @@index([tenantId, action])
  @@map("events")
}

// -----------------------------------------------------------------------------
// Billing (nur im Hosted Mode aktiv)
// -----------------------------------------------------------------------------
// Plan-Definitionen für Self-Hosting komplett deaktivierbar via BILLING_ENABLED=false.
// Im Hosted-Modus mit BILLING_ENABLED=true werden Limits durchgesetzt.

model BillingPlan {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug            String   @unique // free | starter | pro | studio | custom
  name            String
  description     String?
  
  // Limits (null = unbegrenzt)
  storageGib      Int?     // Speicher in GiB
  galleriesMax    Int?     // max Anzahl aktiver Galerien
  filesPerGallery Int?     // max Files pro Galerie
  usersMax        Int?     // max Studio-Mitglieder
  bandwidthGibPerMonth Int? // Traffic-Limit
  
  // Feature-Gates
  customDomain    Boolean  @default(false)
  whiteLabel      Boolean  @default(false)
  watermarking    Boolean  @default(true)
  analytics       Boolean  @default(false)
  
  // Stripe-Integration
  stripePriceIdMonthly String?
  stripePriceIdYearly  String?
  priceMonthlyCents    Int?
  priceYearlyCents     Int?
  currency             String  @default("EUR")
  
  isActive        Boolean  @default(true)
  sortOrder       Int      @default(0)

  /// Lumio-Cut bei Print-Shop-Bestellungen, in Basispunkten.
  /// 0 = kein Cut (Default). 250 = 2.5%. Tenant kann via
  /// TenantPrintShopConfig.applicationFeeBpsOverride ueberschreiben
  /// (z.B. fuer Bestandskunden oder Sondervereinbarungen).
  printApplicationFeeBps Int @default(0)

  subscriptions   BillingSubscription[]
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@map("billing_plans")
}

model BillingSubscription {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId           String   @unique @db.Uuid
  tenant             Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  planId             String   @db.Uuid
  plan               BillingPlan @relation(fields: [planId], references: [id])
  
  status             String   // trialing | active | past_due | canceled | unpaid
  billingInterval    String   // monthly | yearly
  
  // Stripe
  stripeCustomerId   String?
  stripeSubscriptionId String? @unique

  // Subscription-Item-IDs — jedes Stripe-Subscription-Item entspricht
  // einer Price (Plan oder Storage-Pack). Wir tracken sie separat,
  // damit Webhook-Updates und Storage-Pack-Quantity-Changes gezielt
  // das richtige Item updaten können (POST /subscription_items/<id>).
  stripePlanItemId         String?
  stripeStorageAddonItemId String?
  
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  cancelAtPeriodEnd  Boolean  @default(false)
  trialEndsAt        DateTime?
  
  // Aktuelle Nutzung (wird vom Worker periodisch geupdatet)
  storageBytesUsed   BigInt   @default(0)
  bandwidthBytesUsed BigInt   @default(0)  // monatlich, wird zurückgesetzt
  galleriesCount     Int      @default(0)

  // Zusätzlich zum Plan-Speicher gekaufte 50-GiB-Packs. Wird in
  // Sprint 2 vom Stripe-Webhook gepflegt (eines pro gekauftem
  // Storage-Pack-Subscription-Item).
  storageAddonGib    Int      @default(0)

  // Karenz-Tracking: gesetzt wenn die Subscription past_due geblieben
  // ist und der Tenant auf read-only-Modus eskaliert wurde. Wird beim
  // erfolgreichen Payment wieder auf null gesetzt.
  readOnlySince      DateTime?
  
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  
  @@map("billing_subscriptions")
}

// Einzelne Abrechnungspositionen für überzogene Nutzung (Usage-based Billing)
model BillingUsageRecord {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String   @db.Uuid
  
  kind        String   // storage_overage | bandwidth_overage | extra_user
  quantity    BigInt   // Einheit je nach kind (Bytes, Anzahl, ...)
  unitPriceCents Int
  periodStart DateTime
  periodEnd   DateTime
  
  reportedToStripeAt DateTime?
  
  createdAt   DateTime @default(now())
  
  @@index([tenantId, periodStart])
  @@map("billing_usage_records")
}

// -----------------------------------------------------------------------------
// Stripe-Webhook-Events: Dedup + Audit-Trail
// -----------------------------------------------------------------------------
// Stripe garantiert at-least-once delivery für Webhooks. Bei Network-Flakes
// oder unserem 5xx kommt derselbe Event mehrfach an. Wir tracken die
// Event-IDs hier und skippen duplicates beim Worker-Processing.
//
// Plus: ein Auditing-Trail, wer wann welchen Webhook empfangen hat. Wichtig
// für Debugging ("warum ist die Subscription auf past_due gegangen?").
//
// Lifecycle:
//   1. POST /billing/webhook empfängt Event, prüft Signatur, schreibt
//      Row mit status='received', enqueued Job in Redis-Stream.
//   2. Stripe-Worker holt Job, processed Event-Body, updated Subscription/
//      Tenant-Felder. Setzt status='processed' (oder 'failed' bei Error).
//   3. Doppelter Receive: API prüft existing Row, skippt enqueue.
model StripeWebhookEvent {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  // Stripe's Event-ID (z.B. "evt_1234abcd"). Unique-Constraint sorgt
  // für Dedup: bei doppeltem Receive würde der INSERT fehlschlagen,
  // wir fangen den unique-conflict ab und skippen.
  stripeEventId String @unique

  // Event-Type ("customer.subscription.updated", "invoice.paid", etc.)
  type        String

  // Roher Event-Body (JSON) — der Worker arbeitet damit. Bei
  // großen Events (z.B. Invoice mit vielen Items) sind das ~5-50 KB.
  payload     Json

  // "received" → enqueued → "processed" / "failed"
  status      String   @default("received")
  errorMessage String?

  // Beziehungs-Felder: bei welchem Tenant ist das angekommen?
  // Können auch null sein, wenn der Event vor dem Customer-Mapping
  // ankommt (z.B. checkout.session.completed bevor wir die customer-
  // id zum Tenant gemappt haben).
  tenantId    String?  @db.Uuid

  createdAt   DateTime @default(now())
  processedAt DateTime?

  @@index([tenantId, createdAt])
  @@index([type, createdAt])
  @@index([status, createdAt])
  @@map("stripe_webhook_events")
}

// -----------------------------------------------------------------------------
// Webhooks (Outbound)
// -----------------------------------------------------------------------------
// Pro Tenant können Studio-User HTTP-Endpunkte hinterlegen, die bei
// bestimmten Events (gallery.created, selection.finalized, ...) aufgerufen
// werden. Damit lassen sich Workflows in Zapier, n8n, eigenen Webhook-
// Receivern oder direkt im Studio-CRM anstoßen, ohne dass Lumio die
// jeweilige Integration selbst kennen muss.
//
// Signatur: jeder Request bekommt einen `X-Lumio-Signature` Header mit
// HMAC-SHA256(secret, timestamp + "." + body) und `X-Lumio-Timestamp`.
// Empfänger verifizieren das wie bei Stripe/GitHub. Das Secret wird beim
// Anlegen einmal angezeigt und ist danach (gehashed) nur noch zur
// Signatur-Erzeugung im API-Code verfügbar — UI rendert es nicht mehr.
//
// Auslieferung: nicht synchron im Request-Pfad! Der Aufrufer publiziert
// nur in einen Redis-Stream; ein Worker macht den HTTP-POST mit Retries.
// Sonst würde ein langsamer/down Webhook-Empfänger Studio-Operationen
// verzögern oder fehlschlagen lassen.
//
// Events ist ein String-Array — wir validieren auf Anwendungsebene gegen
// eine Whitelist, nicht via DB-Enum, damit das Hinzufügen neuer Events
// keine Migration braucht.
model Webhook {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String   @db.Uuid
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  label       String   // freie Bezeichnung im Studio, z.B. "Zapier Hochzeit"
  url         String   // muss https sein (keine Plain-HTTP-Auslieferungen
                       // in Produktion — Signatur-Headers sind sonst sinnlos)
  secret      String   // wird mit dem Body signiert (HMAC-SHA256)
  events      String[] // Whitelist subscriebter Events
  active      Boolean  @default(true)
  
  // Stats für die Studio-UI
  lastDeliveryAt   DateTime?
  lastDeliveryOk   Boolean?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  deliveries  WebhookDelivery[]
  
  @@index([tenantId])
  @@map("webhooks")
}

// Audit-Log der versuchten Auslieferungen.
// Wir behalten alle Deliveries (auch erfolgreiche) für eine begrenzte
// Frist, damit das Studio bei Debug-Fragen ("warum hat Zapier den Job
// nicht gestartet?") nachschauen kann. Aufräumen: Cron-Job, der ältere
// als 30 Tage entfernt — verfasst, wenn das Volumen das nötig macht.
model WebhookDelivery {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  webhookId   String   @db.Uuid
  webhook     Webhook  @relation(fields: [webhookId], references: [id], onDelete: Cascade)
  
  eventType   String   // z.B. "gallery.created"
  payload     Json     // das, was wir als Body gepostet haben
  
  // Status der Auslieferung
  status      String   // pending | sent | failed | dead
  httpStatus  Int?     // HTTP-Status-Code der Antwort
  errorMessage String?
  
  // Retry-Verwaltung
  attempts    Int      @default(0)
  nextAttemptAt DateTime?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([webhookId, createdAt])
  @@index([status, nextAttemptAt])
  @@map("webhook_deliveries")
}

// -----------------------------------------------------------------------------
// Tags
// -----------------------------------------------------------------------------
// Hierarchisches Label-System pro Tenant. Tags lassen sich an Galleries
// und Files heften und im Studio zum Filtern verwenden. Hierarchie über
// parentId — ein Tag kann ein anderes als Parent haben, was die UI als
// breadcrumb ("Event / Hochzeit") darstellt. DB-seitig kein cycle-check;
// das Erstellungs-Endpoint validiert das.
//
// name ist innerhalb desselben Parent unique (case-insensitive auf
// Application-Seite — DB-collation würden wir extra konfigurieren
// müssen, lohnt nicht).
//
// color als HEX-String ("#RRGGBB"). Wir validieren das Format auf
// API-Seite; DB nimmt jeden String.
//
// onDelete: Cascade auf den Joins, damit ein gelöschter Tag automatisch
// aus allen Galerien/Files verschwindet.
model Tag {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String   @db.Uuid
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  name        String
  color       String   @default("#94a3b8")  // slate-400 als neutraler default
  parentId    String?  @db.Uuid
  parent      Tag?     @relation("TagHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children    Tag[]    @relation("TagHierarchy")
  
  galleries   GalleryTag[]
  files       FileTag[]
  // Smart-Sections die diesen Tag als ihren auto-Tag haben. SetNull
  // auf delete (siehe GallerySection.autoTag).
  autoSections GallerySection[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([tenantId])
  @@index([tenantId, parentId])
  @@map("tags")
}

// Many-to-Many: Gallery ↔ Tag
// Wir nutzen kein Prisma-implizites "@relation(...)" mit doppelseitigen
// arrays, sondern eine explizite Join-Tabelle. Das macht Inserts/Deletes
// klarer und gibt uns optional ein createdAt für "wann wurde das Tag
// gesetzt" — nice für Audit, kostet nichts.
model GalleryTag {
  galleryId   String   @db.Uuid
  tagId       String   @db.Uuid
  gallery     Gallery  @relation(fields: [galleryId], references: [id], onDelete: Cascade)
  tag         Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  
  @@id([galleryId, tagId])
  @@index([tagId])
  @@map("gallery_tags")
}

// Many-to-Many: File ↔ Tag
model FileTag {
  fileId      String   @db.Uuid
  tagId       String   @db.Uuid
  file        File     @relation(fields: [fileId], references: [id], onDelete: Cascade)
  tag         Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  
  @@id([fileId, tagId])
  @@index([tagId])
  @@map("file_tags")
}

// -----------------------------------------------------------------------------
// Super-Admin & Tenant-Verwaltung
// -----------------------------------------------------------------------------
// Eigene Identität, getrennt von den per-Tenant-Usern (users). Begründung:
//   - Klare Trennung von Cross-Tenant-Operationen vs. Tenant-internem Studio
//   - Eigener Session-Cookie (lumio_super_session) — verhindert dass ein
//     Studio-Login versehentlich einen Super-Admin im selben Browser
//     öffnet oder umgekehrt
//   - Eigene Audit-Spur (in Event-Tabelle eventType="super.*")
//   - Owner-/Member-Rollen aus users sind bewusst nicht überladen — Super-
//     Admin ist KEIN Tenant-User, sondern ein Plattform-Operator.
model SuperAdmin {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email        String   @unique
  passwordHash String
  displayName  String
  
  // Wann zuletzt eingeloggt? Reine Anzeige im Self-Service-Bereich.
  lastLoginAt  DateTime?
  
  sessions     SuperAdminSession[]
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  @@map("super_admins")
}

// Setup-Token für initiale Passwort-Wahl beim Onboarding eines Tenant-Owners.
// Beim Anlegen eines Tenant-Owners durch den Super-Admin entsteht ein Token
// dieser Tabelle. Der Owner bekommt eine Mail mit Link
// /auth/setup-password?token=<token> und setzt darüber sein Passwort.
//
// Auch nutzbar für späteren "Passwort vergessen"-Flow — gleiche Tabelle,
// gleicher Token-Lebenszyklus, andere kind-Werte.
model PasswordResetToken {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String   @db.Uuid
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Hash des Tokens (nicht der Token selbst). Wir geben den Klartext-Token
  // an die Mail, speichern aber nur den Hash — falls die DB leaked, sind
  // die Tokens nicht direkt verwendbar.
  tokenHash   String   @unique
  
  // "setup" = initiales Passwort beim Onboarding
  // "reset" = vergessenes Passwort
  // "email_change" = User aendert seine E-Mail-Adresse; payload haelt
  //                  die neue Adresse, die nach Click bestaetigt wird.
  kind        String   @default("setup")

  // Tokentyp-spezifischer Payload als JSON. Aktuell genutzt fuer
  // email_change.newEmail. Bei setup/reset null.
  payload     Json?

  expiresAt   DateTime
  usedAt      DateTime?
  
  createdAt   DateTime @default(now())
  
  @@index([userId, kind])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

// Eigene Session-Tabelle für Super-Admins. Begründung wie bei der eigenen
// SuperAdmin-Tabelle: Trennung von Plattform-Operator vs. Tenant-User.
// Die Sessions-Logik (Hash-only-Storage, 30d TTL, IP/UA-Tracking) ist
// identisch zur normalen Session-Tabelle.
model SuperAdminSession {
  id           String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  superAdminId String     @db.Uuid
  superAdmin   SuperAdmin @relation(fields: [superAdminId], references: [id], onDelete: Cascade)
  
  tokenHash    String     @unique
  ipAddress    String?
  userAgent    String?
  
  expiresAt    DateTime
  createdAt    DateTime   @default(now())
  
  @@index([superAdminId])
  @@index([expiresAt])
  @@map("super_admin_sessions")
}

// -----------------------------------------------------------------------------
// Smart Collections — gespeicherte Filter-Macros über die Galerien-Liste
// -----------------------------------------------------------------------------
// "Wie Lightroom Smart Collections" — der User kann einen Filter-Set
// (Mode + Status + Tags + Datums-Range) unter einem Namen speichern und
// später aus der Sidebar wieder aufrufen. Die Collection ändert keine
// Daten, sie ist eine reine Such-Hilfe.
//
// Filter-Definition liegt in einem JSON-Feld, damit wir später File-Level-
// Filter (Kind, Likes, etc.) dazupacken können ohne Migration. Das aktuelle
// MVP-Schema ist in apps/api/src/services/smart-collection-filter.ts
// dokumentiert und validiert (Zod).
//
// Sortierung in der Sidebar via sortOrder; per Studio-UI änderbar
// (Drag & Drop).
model SmartCollection {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String   @db.Uuid
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  // Sichtbar nur für den Ersteller. Falls wir später Team-Sharing wollen
  // (z.B. ownerScope='tenant'), bauen wir das als separate Spalte dazu.
  ownerId     String   @db.Uuid
  owner       User     @relation("SmartCollectionOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  
  name        String   // "Hochzeiten 2025 mit offener Auswahl"
  icon        String?  // optional emoji oder lucide-icon-key
  filter      Json     // siehe smart-collection-filter.ts Schema
  sortOrder   Int      @default(0)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([tenantId, ownerId])
  @@map("smart_collections")
}

// -----------------------------------------------------------------------------
// Tenant-Export (Datenexport für DSGVO / Pre-Delete-Backup / Self-Service)
// -----------------------------------------------------------------------------
// Ein TenantExport gruppiert mehrere Galerie-ZIPs. Der Trigger kann sein:
//   - Studio-User exportiert einzelne Galerie ("source = studio")
//   - Studio-User exportiert alle Galerien ("source = studio_all")
//   - Super-Admin exportiert für Tenant ("source = super_admin")
//
// Pro Galerie wird ein eigener ZIP-Build-Job ausgelöst (TenantExportItem).
// So skaliert das auch bei großen Tenants mit 200+ Galerien — die
// Browser-Downloads sind separat, parallel möglich, und ein einzelner
// fehlgeschlagener Build sprengt nicht das ganze Bundle.
//
// Bei source='super_admin' im Archive-Karenz-Zeitraum: Optional wird ein
// ExportToken generiert. Tenant kann ohne Login per Mail-Link runterladen.
model TenantExport {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String   @db.Uuid
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Wer hat den Export angefordert (Audit + UI).
  //   studio       = einzelne Galerie aus dem Studio
  //   studio_all   = alle Galerien aus dem Studio (Studio-Bulk-Export)
  //   super_admin  = Super-Admin (z.B. vor Hard-Delete)
  source      String

  // Status:
  //   pending  = Items werden erstellt, Worker enqueued
  //   building = mindestens ein Item baut noch
  //   ready    = alle Items haben einen Endzustand (ready oder failed)
  //   expired  = Ablauffrist erreicht, Files in S3 sind weg
  status      String   @default("pending")

  // Optional: User-ID des auslösenden Studio-Users. Bei super_admin null.
  triggeredByUserId String?  @db.Uuid

  // Optional: Super-Admin-ID. Bei studio-Trigger null.
  triggeredBySuperAdminId String? @db.Uuid

  // Wenn gesetzt: Token-basierter Download für Tenant ohne Login möglich.
  // Wird nur bei super_admin-Triggers für archived Tenants gesetzt.
  token       ExportToken?

  items       TenantExportItem[]

  // 30 Tage nach Erstellung. Cleanup-Job entfernt expired Exports.
  expiresAt   DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId, createdAt])
  @@index([expiresAt])
  @@map("tenant_exports")
}

// Pro Galerie ein ZIP-Item.
model TenantExportItem {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  exportId    String   @db.Uuid
  export      TenantExport @relation(fields: [exportId], references: [id], onDelete: Cascade)

  galleryId   String?  @db.Uuid  // null wenn Galerie inzwischen gelöscht
  // Wir snapshotten Galerie-Name + Slug, damit nach Gallery-Delete
  // im Export-Ordner trotzdem ein sinnvoller Name steht.
  gallerySlug String
  galleryName String

  status      String   @default("pending") // pending | building | ready | failed
  storageKey  String?
  sizeBytes   BigInt?
  fileCount   Int?
  errorMessage String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([exportId])
  @@map("tenant_export_items")
}

// Token-basierter Download-Zugang für archived Tenants (Use Case A).
// Eine Reihe pro Export, optional. Token wird in der Mail an den
// Tenant-Owner verschickt; öffnet ohne Login eine Download-Seite.
model ExportToken {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  exportId    String   @unique @db.Uuid
  export      TenantExport @relation(fields: [exportId], references: [id], onDelete: Cascade)

  // Random String, lang genug für Sicherheit gegen Brute-Force.
  // 32 Bytes base64url ≈ 43 Chars.
  token       String   @unique

  // Wenn gesetzt: Token wurde bereits einmal verwendet (z.B. wenn wir
  // mal einmalige Tokens machen wollen). Aktuell unbegrenzte Nutzung
  // bis expiresAt, das Feld ist nur für Audit/Forensik.
  firstAccessAt DateTime?
  accessCount   Int      @default(0)

  expiresAt   DateTime
  createdAt   DateTime @default(now())

  @@map("export_tokens")
}

// -----------------------------------------------------------------------------
// Super-Admin Interne Notizen
// -----------------------------------------------------------------------------
// Notizen die NUR der Super-Admin sieht — niemals im Studio sichtbar.
// Use-Cases: "Hat angerufen wegen X", "VIP-Kunde", "Zahlt manchmal spät",
// "Hat Sonder-Konditionen", etc.
//
// Bewusst minimalistisch: kein Markdown, keine Edits (Append-only-
// Timeline), keine Threads/Mentions. Wenn der Solo-Operator das mal
// erweitern will, ist die Architektur einfach genug.
model TenantNote {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String   @db.Uuid
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  body         String

  /// Super-Admin der die Notiz angelegt hat. Wenn mal mehrere Super-
  /// Admins existieren, kann man so sehen wer was geschrieben hat.
  authorId     String   @db.Uuid
  authorEmail  String   // gemerkt, damit auch nach Super-Admin-Loeschung lesbar
  authorName   String?

  createdAt    DateTime @default(now())

  @@index([tenantId, createdAt])
  @@map("tenant_notes")
}

// -----------------------------------------------------------------------------
// MRR-Snapshots (taeglich gepflegt durch Background-Job)
// -----------------------------------------------------------------------------
// Bewahrt einen historischen Verlauf der MRR fuer Trend-Analyse. Wir
// rechnen die aktuelle MRR jederzeit live aus, aber fuer den 12-
// Wochen-Trend brauchen wir Snapshots. Ein Snapshot pro Tag reicht —
// MRR aendert sich nicht zwischen Mittag und Abend dramatisch.
model MrrSnapshot {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  /// Tag des Snapshots (UTC). UNIQUE damit der Cron-Job idempotent
  /// laeuft — bei mehrfacher Ausfuehrung am selben Tag wird nichts
  /// dupliziert.
  date            DateTime @unique @db.Date

  /// Aktuelle MRR in cents, normalisiert auf monatlich. Yearly-Subs
  /// gehen mit /12 ein.
  mrrCents        Int
  /// Potenzielle MRR aus trialing-Subs (was reinkaeme wenn alle
  /// konvertieren). Forecast-Zahl, kein realer Umsatz.
  trialingMrrCents Int
  /// Anzahl active+past_due Subscriptions (zaehlt zur MRR mit)
  activeSubs      Int
  trialingSubs    Int

  /// Aufschluesselung pro Plan als JSON. Schema:
  /// { "starter": { mrrCents, count }, "pro": { ... }, ... }
  perPlan         Json

  createdAt       DateTime @default(now())

  @@index([date])
  @@map("mrr_snapshots")
}

// -----------------------------------------------------------------------------
// System-Announcements (Wartungs-/Update-Banner an alle Studios)
// -----------------------------------------------------------------------------
// Super-Admin kann Banner schalten, die in JEDEM Studio im StudioShell
// angezeigt werden. Use-Cases:
//   - geplantes Wartungsfenster ("am Sonntag 02:00 UTC sind Lumio-Dienste
//     fuer 30min nicht erreichbar")
//   - Hinweis auf neue Features
//   - akute Outage-Notification
//
// Severity entscheidet ueber Farbe und Dismissibility-Behavior. 'critical'
// wird vom Frontend NICHT als dismiss-bar behandelt — wenn was richtig
// brennt, soll der User es nicht wegklicken koennen.
model SystemAnnouncement {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title        String
  body         String

  /// info | warning | critical
  severity     String   @default("info")

  /// Wenn null: ab sofort aktiv. Sonst ab dem Zeitpunkt.
  activeFrom   DateTime?
  /// Wenn null: aktiv bis manuell deaktiviert.
  activeUntil  DateTime?

  /// Wenn false: User kann den Banner NICHT wegklicken. Default true.
  /// Critical-Severity ignoriert das ohnehin.
  dismissible  Boolean  @default(true)

  /// Super-Admin der das Announcement angelegt hat (denormalisiert).
  createdById      String   @db.Uuid
  createdByEmail   String

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([activeFrom, activeUntil])
  @@map("system_announcements")
}

// -----------------------------------------------------------------------------
// Broadcast-Mails (Super-Admin an alle Tenant-User)
// -----------------------------------------------------------------------------
// Bewusst KEIN Redis-Queue, KEIN Python-Worker fuer Versand — Lumio ist
// Solo-SaaS mit Tenant-Zahlen die in einen In-Process-Loop passen.
// Der API-Prozess feuert processBroadcast(id) als async fire-and-forget,
// updated counts inkrementell in der DB. Bei Process-Crash erkennt der
// Sweeper offene Broadcasts und kann sie resumen (status='sending'
// laenger als X Minuten → resume).
model Broadcast {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  subject         String
  bodyMarkdown    String
  /// Gerendetes HTML, gespeichert beim Anlegen — der konkrete Output
  /// soll auch in 6 Monaten exakt rekonstruierbar sein, auch wenn das
  /// Layout-Template sich aendert.
  bodyHtml        String

  /// Empfaenger-Zielgruppe. Siehe services/broadcast.ts listAudienceUsers().
  audience        String

  /// pending | sending | finished | failed | cancelled
  status          String   @default("pending")

  totalRecipients Int      @default(0)
  sentCount       Int      @default(0)
  failedCount     Int      @default(0)
  optedOutSkippedCount Int @default(0)

  startedAt       DateTime?
  finishedAt      DateTime?
  /// Letzte Status-Update-Zeit — fuer Stale-Detection beim Sweeper-Resume
  lastProgressAt  DateTime?

  /// Optionale Fehler-Nachricht bei status='failed' (sammelt erste 500 Zeichen)
  errorMessage    String?

  /// Super-Admin der das Broadcast erstellt hat (denormalisiert)
  createdById     String   @db.Uuid
  createdByEmail  String

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([status, lastProgressAt])
  @@map("broadcasts")
}

// -----------------------------------------------------------------------------
// Feature-Flags pro Tenant
// -----------------------------------------------------------------------------
// Erlaubt schrittweisen Feature-Rollout: Print-Shop fuer ausgewaehlte
// Beta-Tester, Lightroom-Plugin nur fuer Pro+, etc.
//
// Schluessel sind in services/feature-flags.ts zentral definiert (TypeScript
// enum-aehnlich) — nur dort registrierte Keys werden im UI angezeigt.
//
// Wenn kein Eintrag existiert: gilt der Default aus der Definition.
model TenantFeatureFlag {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String   @db.Uuid
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  flagKey     String

  enabled     Boolean

  /// Super-Admin der den Flag gesetzt hat
  setById     String   @db.Uuid
  setByEmail  String

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([tenantId, flagKey])
  @@index([flagKey])
  @@map("tenant_feature_flags")
}

// -----------------------------------------------------------------------------
// Print-Shop (Feature-Flag: print_shop)
// -----------------------------------------------------------------------------
// Komplett deaktivierbar via TenantFeatureFlag 'print_shop'. Wenn aus,
// liefern alle /print/* Routes 404 und das Frontend rendert nichts vom
// Print-Shop. Schema-Tabellen koennen leer bleiben — keine Auswirkung
// auf Non-Print-Tenants.
//
// Provider-Architektur:
//   1. Code-Registry (services/print/providers.ts): definiert WELCHE
//      Provider Lumio grundsaetzlich unterstuetzt (whitewall, saal, ...).
//      Dort sind auch die jeweiligen Adapter-Implementierungen — Self-
//      Print voll implementiert, externe Labs als Stubs fuer Phase 2+.
//
//   2. SuperAdminPrintProviderConfig: Super-Admin schaltet pro Provider
//      global an/aus. Default = alle aus. So kannst du z.B. WhiteWall
//      einschalten sobald die API-Integration fertig ist, ohne dass die
//      anderen Labs schon auftauchen.
//
//   3. TenantPrintProvider: Pro Tenant aktivierte Provider. Enthaelt
//      die Lab-API-Credentials des Fotografen (encrypted at rest).
//      Self-Print braucht keine Credentials.
//
// Bezahlmodi:
//   - stripe_connect: Endkunde zahlt online, Geld geht direkt an den
//     Fotografen ueber sein Stripe-Connect-Express-Konto. Lumio nimmt
//     optionalen application_fee_amount-Cut (BillingPlan-Setting).
//   - offline_invoice: Fotograf rechnet selbst mit Endkunde ab
//     (Rechnung/Ueberweisung). Lumio sammelt nur Bestellung + Adresse,
//     Fotograf druckt nach Zahlungseingang.
// Tenant kann pro Galerie/Produkt entscheiden was er anbietet.

/// Super-Admin-globale Provider-Aktivierung. Ein Eintrag pro Provider-
/// Key aus der Code-Registry. Default-Verhalten wenn kein Eintrag
/// existiert: provider gilt als NICHT aktiviert.
model SuperAdminPrintProviderConfig {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  providerKey  String   @unique
  enabled      Boolean  @default(false)
  /// Optionale interne Notiz vom Super-Admin (z.B. 'API-Key getestet am
  /// 28.05., Beta-Stage').
  adminNotes   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("super_print_provider_config")
}

/// Tenant-weite Print-Shop-Einstellungen. Eine pro Tenant.
model TenantPrintShopConfig {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId        String   @unique @db.Uuid
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  /// Globaler Print-Shop-Schalter dieses Tenants. Auch wenn das Feature-
  /// Flag aktiv ist und Provider eingerichtet sind, kann der Fotograf
  /// das ganze Modul temporaer ausblenden (z.B. Urlaubsmodus).
  enabled         Boolean  @default(false)

  /// Studio-Name fuer Order-Mails. Wenn null: tenant.displayName.
  studioDisplayName String?
  /// Support-Mail fuer Endkunden-Rueckfragen zu Bestellungen.
  /// Wenn null: Owner-Email des Tenants.
  supportEmail    String?

  /// MwSt-Modus. 'inclusive' = Preise verstehen sich brutto. 'exclusive'
  /// = netto, MwSt wird im Checkout aufgeschlagen. DE-Default: inclusive.
  vatHandling     String   @default("inclusive")
  /// Standard-MwSt-Satz in Basispunkten (1900 = 19%). Pro-Produkt
  /// ueberschreibbar falls noetig (z.B. Photobooks 7% nach §12 UStG).
  defaultVatBps   Int      @default(1900)
  currency        String   @default("EUR")

  /// Pfad zu Tenant-eigenen AGB (auf seiner Website). Wird im Endkunden-
  /// Checkout verlinkt. Pflicht in DE — Endkunde muss zustimmen.
  termsUrl        String?
  privacyUrl      String?

  /// Application-Fee-Override (Basispunkte). Wenn null: gilt
  /// BillingPlan.printApplicationFeeBps. 100 = 1%.
  applicationFeeBpsOverride Int?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("tenant_print_shop_config")
}

/// Stripe-Connect-Express-Account des Tenants. Optional — Tenants
/// koennen Print-Shop auch nur im offline_invoice-Modus betreiben.
model TenantStripeConnect {
  id                       String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId                 String   @unique @db.Uuid
  tenant                   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  stripeConnectedAccountId String   @unique
  /// Aus Stripe-Webhook: 'charges_enabled' — darf der Account Geld einnehmen?
  chargesEnabled           Boolean  @default(false)
  /// Aus Stripe-Webhook: 'payouts_enabled' — darf der Account Auszahlungen?
  payoutsEnabled           Boolean  @default(false)
  /// 'details_submitted' — Onboarding-Formular ist komplett ausgefuellt
  detailsSubmitted         Boolean  @default(false)

  onboardedAt              DateTime?
  lastWebhookSyncAt        DateTime?

  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  @@map("tenant_stripe_connect")
}

/// Pro Tenant aktivierter Print-Provider. Self-Print ist immer
/// implizit verfuegbar (kein Eintrag noetig, falls die Code-Registry
/// das so vorsieht). Externe Labs brauchen einen Eintrag mit
/// (encrypted) Credentials.
model TenantPrintProvider {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId      String   @db.Uuid
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  /// Key aus services/print/providers.ts. Sanity-Check im Service-
  /// Layer — kein FK weil die Registry Code ist, keine Tabelle.
  providerKey   String

  enabled       Boolean  @default(true)

  /// Anzeigename im Studio-UI ('Mein WhiteWall-Account', etc.). Wenn
  /// null: Provider-Default-Label.
  displayName   String?

  /// Adapter-spezifische Credentials. Encrypted at rest via libsodium
  /// secretbox (siehe services/print/credentials.ts). Schema des
  /// Klartext-Objects ist providerspezifisch.
  credentialsEnc Bytes?

  /// Wenn true: dieser Provider ist der Default beim Anlegen neuer
  /// Produkte. Pro Tenant nur einer.
  isDefault     Boolean  @default(false)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([tenantId, providerKey])
  @@index([tenantId])
  @@map("tenant_print_provider")
}

/// Produktkatalog des Tenants. Pro Produkt: ein Print-Typ
/// (Klassischer Print, Leinwand, Photobook). Varianten in
/// PrintProductVariant.
model PrintProduct {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String   @db.Uuid
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name         String
  description  String?

  /// Welcher Provider fulfilled diese Produkte. Ein Produkt = ein
  /// Provider. Bei Provider-Wechsel: neues Produkt anlegen.
  providerKey  String

  /// Adapter-spezifische Produkt-Referenz (Lab-SKU). null fuer
  /// manual_self_print.
  providerProductRef String?

  /// Anzeige-Kategorie fuer Filterung. Frei-Text aber typisch:
  /// 'print', 'canvas', 'photobook', 'frame', 'metal_print'.
  category     String   @default("print")

  /// MwSt-Override fuer Produkte mit anderem Satz (z.B. Photobooks 7%).
  /// Wenn null: TenantPrintShopConfig.defaultVatBps.
  vatBpsOverride Int?

  /// Anzeige-Reihenfolge im Endkunden-Picker (kleinster Wert zuerst).
  displayOrder Int      @default(0)
  enabled      Boolean  @default(true)

  variants     PrintProductVariant[]

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([tenantId, enabled])
  @@map("print_products")
}

/// Eine konkrete Variante (Groesse + Material) eines Produkts. Hier
/// liegt der Preis. Beispiel: Produkt 'Premium-Foto-Print' hat Varianten
/// '20x30 Glanz' (15 Euro), '30x45 Glanz' (25 Euro), '40x60 Matt' (35 Euro).
model PrintProductVariant {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  printProductId  String   @db.Uuid
  printProduct    PrintProduct @relation(fields: [printProductId], references: [id], onDelete: Cascade)

  name            String

  /// Groesse in Millimeter. Wir speichern fix metrisch — Conversions
  /// fuer US-Maerkte falls noetig im Frontend.
  widthMm         Int
  heightMm        Int

  /// Required Aspect-Ratio (width:height). Wenn gesetzt, muss der
  /// Endkunde im Crop-Tool den Ausschnitt passend zuschneiden. null =
  /// freier Crop. Beispiel: 2:3 ist 0.6667.
  aspectRatio     Float?

  /// 'matte', 'gloss', 'pearl', 'metallic', 'fine_art', ...
  finishType      String?

  /// Lab-spezifische Varianten-Referenz (z.B. WhiteWall-SKU).
  providerVariantRef String?

  /// Endkunden-Preis (brutto wenn vatHandling=inclusive). Always in
  /// kleinster Waehrungseinheit (cents).
  priceCents      Int

  /// Was das LAB dem Fotograf kostet. Optional — nur fuer Margin-
  /// Anzeige im Studio. Bei manual_self_print null.
  costCents       Int?

  displayOrder    Int      @default(0)
  enabled         Boolean  @default(true)

  orderItems      PrintOrderItem[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([printProductId, enabled])
  @@map("print_product_variants")
}

/// Versandmethoden pro Tenant. Bei API-Lab-Providern oft vom Lab
/// generiert; bei Self-Print vom Fotograf manuell konfiguriert.
model ShippingMethod {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId      String   @db.Uuid
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  /// Welcher Provider verschickt? Bei Self-Print 'manual_self_print',
  /// sonst der Lab-Provider-Key. Bestimmt welches Address-Schema fuer
  /// die Bestellung gilt.
  providerKey   String

  name          String   // z.B. 'DHL Standard', 'DHL Express', 'Pickup'
  priceCents    Int
  estimatedDaysMin Int?
  estimatedDaysMax Int?

  /// ISO-3166-1 alpha-2 Codes ('DE', 'AT', 'CH'). Leeres Array =
  /// alle Laender.
  countries     String[]

  /// Provider-spezifische Referenz (z.B. WhiteWall-Shipping-Method-ID).
  providerShippingRef String?

  enabled       Boolean  @default(true)
  displayOrder  Int      @default(0)

  printOrders   PrintOrder[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([tenantId, enabled])
  @@map("shipping_methods")
}

/// Eine Endkunden-Bestellung. Eine pro Checkout. Items in
/// PrintOrderItem, Status-Verlauf in PrintOrderEvent.
model PrintOrder {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  /// Order-Number fuer Endkunden ('LP-2026-000123' o.ae.). Kurz,
  /// sequentiell, einfach am Telefon vorlesbar. Generiert im
  /// Service-Layer.
  orderNumber     String   @unique

  tenantId        String   @db.Uuid
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  /// Aus welcher Galerie stammt die Bestellung — wichtig fuer
  /// Asset-Lookup + Studio-Reporting ('was hat sich am meisten
  /// verkauft pro Galerie?').
  galleryId       String   @db.Uuid
  gallery         Gallery  @relation(fields: [galleryId], references: [id], onDelete: Cascade)

  /// Endkunden-Daten. Nicht als FK auf eine User-Tabelle — Endkunden
  /// sind keine User in unserem Sinne. Email ist Pflicht fuer Order-
  /// Bestaetigung.
  guestEmail      String
  guestName       String

  /// Liefer- und Rechnungsadresse als JSON. Schema:
  ///   { street, street2?, postalCode, city, region?, countryCode,
  ///     phone? }
  /// Wir speichern als JSON statt Spalten, weil Adress-Schemas
  /// laenderspezifisch sind und sich aendern. Plus: Audit-Snapshot —
  /// wenn der Endkunde spaeter umzieht, soll die Order-Adresse
  /// historisch bleiben.
  shippingAddress Json
  billingAddress  Json?

  /// Bezahlmodus. 'stripe_connect' = online via Stripe Connect,
  /// 'offline_invoice' = Fotograf rechnet selbst ab.
  paymentMode     String

  /// Stripe-Referenzen (nur bei stripe_connect).
  stripePaymentIntentId String?  @unique
  stripeChargeId        String?

  /// Geld-Beträge. Alle in kleinster Waehrungseinheit.
  subtotalCents   Int
  shippingCents   Int      @default(0)
  taxCents        Int      @default(0)
  totalCents      Int
  /// Lumio-Cut bei diesem Order. Schon in totalCents enthalten — wir
  /// speichern ihn separat fuer Reporting.
  applicationFeeCents Int  @default(0)
  currency        String   @default("EUR")

  /// Lebenszyklus. Linear ausser bei Cancel/Refund die alle
  /// Zwischenzustaende ueberspringen.
  /// 'draft'      = User im Checkout, noch nicht bezahlt
  /// 'pending_payment' = Stripe-Payment-Intent erstellt, warten auf Zahlung
  /// 'paid'       = Zahlung eingegangen (bei stripe_connect) oder
  ///                vom Fotograf manuell als bezahlt markiert
  /// 'in_production' = An Lab uebergeben (api) oder Fotograf hat
  ///                'in Druck'-Status gesetzt
  /// 'shipped'    = Tracking-Nummer gesetzt
  /// 'delivered'  = Aus Carrier-Webhook oder manuell vom Fotograf
  /// 'cancelled'  = Bestellung storniert (vor Production)
  /// 'refunded'   = Zahlung an Endkunde zurueckgegeben
  status          String   @default("draft")

  /// Welcher Provider hat die Bestellung gefulfilled?
  providerKey     String

  /// Lab-Bestell-Nummer (bei API-Labs nach erfolgreichem Submit).
  providerOrderRef String?

  /// Versand
  shippingMethodId    String?  @db.Uuid
  shippingMethod      ShippingMethod? @relation(fields: [shippingMethodId], references: [id])
  trackingNumber      String?
  trackingCarrier     String?
  trackingUrl         String?

  /// Notizen
  /// guestNote: vom Endkunden im Checkout ('bitte als Geschenk verpacken')
  guestNote       String?
  /// studioNote: nur fuer den Fotograf, nicht fuer den Endkunden
  studioNote      String?

  /// Zeitstempel fuer Lifecycle
  paidAt          DateTime?
  productionStartedAt DateTime?
  shippedAt       DateTime?
  deliveredAt     DateTime?
  cancelledAt     DateTime?
  refundedAt      DateTime?

  items           PrintOrderItem[]
  events          PrintOrderEvent[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([tenantId, status])
  @@index([tenantId, createdAt])
  @@index([galleryId])
  @@map("print_orders")
}

model PrintOrderItem {
  id                    String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  printOrderId          String   @db.Uuid
  printOrder            PrintOrder @relation(fields: [printOrderId], references: [id], onDelete: Cascade)

  printProductVariantId String   @db.Uuid
  printProductVariant   PrintProductVariant @relation(fields: [printProductVariantId], references: [id])

  /// Welches Galerie-Bild gedruckt wird.
  fileId                String   @db.Uuid
  file                  File     @relation(fields: [fileId], references: [id], onDelete: Restrict)

  /// Crop-Region fuer Aspect-Ratio-Anpassung. JSON-Schema:
  ///   { x, y, width, height } in [0..1] Bild-Koordinaten
  /// null = ganzes Bild
  crop                  Json?

  quantity              Int      @default(1)
  unitPriceCents        Int
  totalPriceCents       Int

  /// Lab-spezifische Item-Referenz nach Order-Submit
  providerItemRef       String?

  createdAt             DateTime @default(now())

  @@index([printOrderId])
  @@map("print_order_items")
}

/// Lifecycle-Events einer Bestellung. Append-only Timeline fuer
/// Audit + Studio-UI ('Order-History').
model PrintOrderEvent {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  printOrderId    String   @db.Uuid
  printOrder      PrintOrder @relation(fields: [printOrderId], references: [id], onDelete: Cascade)

  /// 'created', 'payment_initiated', 'paid', 'submitted_to_lab',
  /// 'in_production', 'shipped', 'delivered', 'cancelled', 'refunded',
  /// 'note_added', 'manual_status_change'
  eventType       String

  /// Wer hat das Event ausgeloest. 'system' (Stripe-Webhook, Lab-API-Reply),
  /// 'guest' (Endkunde im Checkout), 'studio' (Fotograf), 'super_admin'.
  actor           String

  /// Optionaler Verweis auf den ausloesenden User (Studio-User oder
  /// Super-Admin). Bei guest/system: null.
  actorUserId     String?  @db.Uuid

  /// Frei-JSON, Event-spezifisch. Z.B. bei 'shipped':
  /// { carrier, trackingNumber, trackingUrl }. Bei 'note_added':
  /// { note }.
  data            Json?

  createdAt       DateTime @default(now())

  @@index([printOrderId, createdAt])
  @@map("print_order_events")
}

// -----------------------------------------------------------------------------
// KI-Auto-Tagging (Feature-Flag: ai_tagging)
// -----------------------------------------------------------------------------
// FileAutoTag haelt Vorschlaege vom Auto-Tagger pro File. Wird vom Worker
// nach erfolgreichem Image-Processing geschrieben (siehe
// apps/worker/tasks/auto_tag.py).
//
// Workflow:
//   1. Worker analysiert das Bild (Etappe 1: rule-based Heuristiken;
//      Etappe 2: CLIP/ML).
//   2. Schreibt FileAutoTag-Rows mit Tag-Name + Confidence (0..1) +
//      Source ('rule_based', 'clip', ...).
//   3. Studio sieht die Vorschlaege im File-Detail, kann pro Vorschlag
//      'accept' (→ wird zu echtem Tag via FileTag + Tag) oder
//      'reject' (status='rejected', Worker schreibt es nicht nochmal).
//
// Tag-Namen werden aus einem festen Vokabular (siehe Worker-Code)
// gezogen, NICHT free-form. Wenn der User custom Tags will, fuegt er
// die manuell ueber das bestehende Tag-System hinzu — Auto-Tagger
// und manuelle Tags koexistieren.
//
// Komplett deaktivierbar via TenantFeatureFlag 'ai_tagging' — wenn aus,
// laeuft der Worker-Task nicht und API liefert 404. Tabelle bleibt leer.
model FileAutoTag {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  fileId      String   @db.Uuid
  file        File     @relation(fields: [fileId], references: [id], onDelete: Cascade)

  /// Tag-Wert (z.B. 'portrait', 'landscape', 'black_and_white', 'indoor').
  /// Werte kommen aus einem festen Vokabular im Worker-Code — kein freier
  /// Text. Damit bleibt die UI-Anzeige konsistent (Uebersetzungen, Farben).
  tagName     String

  /// Konfidenz [0.0..1.0]. Bei rule_based-Source oft binary (0 oder 1),
  /// bei CLIP/ML probabilistisch verteilt.
  confidence  Float

  /// Wo kommt der Vorschlag her. Erlaubt spaeter die Quelle zu sortieren
  /// ('zeig mir nur rule_based-Vorschlaege') und beim Re-Tag andere
  /// Sources unbeeinflusst zu lassen.
  source      String   // 'rule_based' | 'clip' | ...

  /// Status:
  ///   'suggested' — Vorschlag noch nicht reviewed
  ///   'accepted'  — Studio hat 'accept' geklickt; ein FileTag wurde
  ///                 angelegt. Wir behalten die Row, damit Re-Tag den
  ///                 Tag nicht doppelt vorschlaegt.
  ///   'rejected'  — Studio hat 'reject' geklickt; beim naechsten Re-Tag
  ///                 wird dieser Tag fuer dieses File NICHT mehr
  ///                 vorgeschlagen.
  status      String   @default("suggested")

  /// Wer hat reviewed (User-Id). Null bei status='suggested'.
  reviewedBy  String?  @db.Uuid
  reviewedAt  DateTime?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Pro File darf ein Tag nur einmal existieren (egal welche Source).
  // Wenn der Worker laeuft und der Tag schon da ist, macht er Update
  // statt Insert (oder skip).
  @@unique([fileId, tagName])
  @@index([fileId, status])
  @@index([tagName])
  @@map("file_auto_tags")
}

/// Dokumentierter elektronischer Abschluss des Auftragsverarbeitungs-
/// vertrags (AVV). Art. 28 Abs. 9 DSGVO erlaubt das elektronische
/// Format ausdruecklich. Jede Zustimmung ist ein eigener Eintrag, sodass
/// bei neuen AVV-Versionen die Historie erhalten bleibt.
model DpaAcceptance {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId         String   @db.Uuid
  tenant           Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  /// Version des AVV-Templates, der zugestimmt wurde (z.B. "1.0").
  version          String
  /// Wer zugestimmt hat — User-ID plus Namens-Snapshot, falls der User
  /// spaeter geloescht wird, bleibt der Nachweis lesbar.
  acceptedByUserId String?  @db.Uuid
  acceptedByName   String?
  /// IP-Adresse zum Zeitpunkt der Zustimmung (Nachweiszweck).
  ipAddress        String?
  acceptedAt       DateTime @default(now())

  @@index([tenantId])
  @@map("dpa_acceptances")
}
