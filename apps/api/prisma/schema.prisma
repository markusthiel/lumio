// =============================================================================
// Lumio — Prisma Schema
// =============================================================================
// Vollständiges Datenmodell. Migrationen werden mit `npm run prisma:migrate`
// erzeugt und im Container mit `npm run prisma:deploy` ausgerollt.

generator client {
  provider      = "prisma-client-js"
  // native = der Host, auf dem prisma generate gerade läuft (Dev-Maschine).
  // linux-musl-openssl-3.0.x = die Production-Container (node:20-alpine
  // bringt OpenSSL 3 via 'apk add openssl3' mit; siehe Dockerfile).
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// -----------------------------------------------------------------------------
// Multi-Tenancy
// -----------------------------------------------------------------------------
// Im Modus DEPLOYMENT_MODE=single existiert genau EIN Tenant, der automatisch
// beim ersten Start angelegt wird. Im multi-Modus können beliebig viele
// Tenants existieren — z.B. für SaaS-Anbieter.

model Tenant {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug        String   @unique
  name        String
  status      String   @default("active") // active | suspended | archived
  customDomain String? @unique

  // Timestamp wann der Tenant archiviert wurde. Wird beim Archive-
  // Endpoint gesetzt, beim Unsuspend NICHT zurückgesetzt (archive ist
  // einseitig — Unsuspend funktioniert nur aus 'suspended', nicht aus
  // 'archived'). Hard-Delete prüft archivedAt + 30 Tage als Karenz
  // gegen versehentliches sofortiges Wegwerfen.
  archivedAt DateTime?
  
  // Branding auf Tenant-Ebene (kann pro Galerie überschrieben werden)
  brandingId  String?  @db.Uuid
  branding    Branding? @relation("TenantBranding", fields: [brandingId], references: [id])
  
  // Watermark-Konfiguration (siehe docs/KONZEPT.md §9)
  // Wenn watermarkImageKey gesetzt: PNG aus S3 wird als Overlay verwendet.
  // Sonst: watermarkText als wiederholtes Text-Pattern (Default: tenant.name).
  watermarkImageKey String?
  watermarkText     String?

  // Pro-File Upload-Limit in MiB. Null = ENV-Default (MAX_FILE_SIZE_MIB)
  // wird benutzt. Wenn gesetzt, wird beim Upload-Init gegen diesen Wert
  // validiert; aber NIE höher als MAX_UPLOAD_HARD_CAP_MIB (ENV-Schutz
  // gegen Misskonfiguration und SaaS-Missbrauch). Der Wert greift
  // sowohl für Studio-Uploads als auch für Uploads via UploadLink
  // (Upload-Link kann nur darunter sein, nie darüber).
  maxUploadMib Int?
  
  // Billing (siehe BillingSubscription)
  subscription BillingSubscription?
  
  users       User[]
  galleries   Gallery[]
  brandings   Branding[] @relation("TenantBrandings")
  templates   GalleryTemplate[] @relation("TenantTemplates")
  events      Event[]
  webhooks    Webhook[]
  tags        Tag[]
  smartCollections SmartCollection[]
  exports     TenantExport[]

  // Stripe-Customer-ID: lifetime-stabil pro Tenant. Wir setzen sie
  // beim ersten Checkout-Session-Create und nutzen sie wieder bei
  // Plan-Wechseln, Storage-Pack-Käufen, Customer-Portal-Calls.
  // Wenn Tenant gelöscht wird: Stripe-Customer wird NICHT automatisch
  // gelöscht (Audit-Trail bleibt im Stripe-Dashboard). Manuell im
  // Stripe-Dashboard archivieren falls gewünscht.
  stripeCustomerId String?  @unique

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([slug])
  @@map("tenants")
}

// -----------------------------------------------------------------------------
// Auth: Studio-User
// -----------------------------------------------------------------------------
model User {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String   @db.Uuid
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  email        String   @db.Citext
  passwordHash String
  name         String?
  role         String   @default("member") // owner | admin | member
  status       String   @default("active") // active | invited | disabled
  
  // 2FA
  totpSecret   String?
  totpEnabled  Boolean  @default(false)
  // Einmalige Backup-Codes (sha256-gehasht, komma-separiert). Werden beim
  // Verbrauch aus dem String entfernt.
  totpBackupCodes String?
  
  galleries    Gallery[]
  sessions     Session[]
  webauthnCredentials WebauthnCredential[]
  apiTokens    ApiToken[]
  passwordResetTokens PasswordResetToken[]
  smartCollections SmartCollection[] @relation("SmartCollectionOwner")

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  lastLoginAt  DateTime?
  
  @@unique([tenantId, email])
  @@index([email])
  @@map("users")
}

model ApiToken {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String   @db.Uuid
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  name        String   // "Lightroom @ Studio-Mac"
  tokenHash   String   @unique  // sha256 hex
  scopes      String   @default("[\"plugin\"]")  // JSON-Array
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  createdAt   DateTime @default(now())

  @@index([userId])
  @@map("api_tokens")
}

model WebauthnCredential {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId        String   @db.Uuid
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  credentialId  String   @unique
  publicKey     Bytes
  signCount     BigInt   @default(0)
  // transports als JSON-Array gespeichert ('usb','nfc','ble','internal','hybrid').
  // Hilft dem Browser beim Authentifizieren, das richtige Device anzufragen.
  transports    String?
  label         String   // "Mein MacBook", "YubiKey #1" — vom User vergeben

  createdAt     DateTime @default(now())
  lastUsedAt    DateTime?

  @@index([userId])
  @@map("webauthn_credentials")
}

model Session {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  tokenHash String   @unique
  ipAddress String?
  userAgent String?
  
  expiresAt DateTime
  createdAt DateTime @default(now())
  
  @@index([userId])
  @@map("sessions")
}

// -----------------------------------------------------------------------------
// Branding (Whitelabel)
// -----------------------------------------------------------------------------
model Branding {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId      String   @db.Uuid
  tenant        Tenant   @relation("TenantBrandings", fields: [tenantId], references: [id], onDelete: Cascade)
  
  name          String   // interne Bezeichnung, z.B. "Standard", "Hochzeit-Style"
  logoUrl       String?
  faviconUrl    String?
  primaryColor  String   @default("#0f172a")
  accentColor   String   @default("#f59e0b")
  fontFamily    String   @default("Inter")
  introText     String?
  footerText    String?
  customCss     String?
  
  galleries     Gallery[]
  tenantsAsDefault Tenant[] @relation("TenantBranding")
  templates     GalleryTemplate[] @relation("BrandingForTemplates")
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  @@index([tenantId])
  @@map("brandings")
}

// -----------------------------------------------------------------------------
// Galerie-Templates
// -----------------------------------------------------------------------------
// Wiederverwendbare Settings-Bundles, die beim Anlegen einer neuen Galerie
// als Defaults übernommen werden. Beispiel: "Hochzeit" = collaboration-Mode,
// Download aus, Watermark an, Kommentare an, 30 Tage Frist, Branding-X.
//
// Nach dem Anlegen lassen sich alle übernommenen Settings pro Galerie noch
// individuell ändern — das Template ist nur ein Initial-State, kein Lock.
model GalleryTemplate {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId          String   @db.Uuid
  tenant            Tenant   @relation("TenantTemplates", fields: [tenantId], references: [id], onDelete: Cascade)
  
  name              String   // interne Bezeichnung, z.B. "Hochzeit", "Newborn"
  description       String?  // optionale Erklärung für andere Studio-User
  
  // Galerie-Settings
  mode              String   @default("collaboration")  // collaboration | presentation
  downloadEnabled   Boolean  @default(true)
  watermarkEnabled  Boolean  @default(false)
  commentsEnabled   Boolean  @default(true)
  ratingsEnabled    Boolean  @default(true)
  
  // Standard-Ablaufzeit in Tagen ab Erstellung — null = unbegrenzt
  defaultExpiryDays Int?
  
  // Default-Beschreibung für neue Galerien (kann pro Galerie überschrieben)
  defaultDescription String?
  
  // Welches Branding-Profil — null bedeutet "Tenant-Default"
  brandingId        String?  @db.Uuid
  branding          Branding? @relation("BrandingForTemplates", fields: [brandingId], references: [id], onDelete: SetNull)
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  @@index([tenantId])
  @@map("gallery_templates")
}

// -----------------------------------------------------------------------------
// Galerie
// -----------------------------------------------------------------------------
model Gallery {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId        String   @db.Uuid
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  ownerId         String   @db.Uuid
  owner           User     @relation(fields: [ownerId], references: [id])
  
  brandingId      String?  @db.Uuid
  branding        Branding? @relation(fields: [brandingId], references: [id])
  
  slug            String   @unique // kryptografisch zufällig, z.B. 12 chars
  title           String
  description     String?
  
  mode            String   @default("collaboration") // collaboration | presentation
  status          String   @default("draft")          // draft | live | archived
  
  // Zugangskontrolle
  passwordHash    String?
  expiresAt       DateTime?
  
  // Feature-Toggles pro Galerie
  downloadEnabled Boolean  @default(true)
  // Zusatz zu downloadEnabled: wenn true, dürfen Kunden auch die Originale
  // herunterladen (sonst nur die Web-Renditions ~2560px webp). Default true
  // damit existierende Galerien unverändert weiterlaufen — der neue Toggle
  // im Studio gibt Photographen die explizite Wahl "nur Web ausliefern".
  downloadOriginalsEnabled Boolean @default(true)
  watermarkEnabled Boolean @default(false)
  commentsEnabled Boolean  @default(true)
  ratingsEnabled  Boolean  @default(true)
  selectionLimit  Int?     // max Anzahl Auswahl für Kunde
  emailRequired   Boolean  @default(false) // Kunde muss E-Mail eingeben
  
  // Cover-Bild
  coverFileId     String?  @db.Uuid
  
  // ---------------------------------------------------------------------------
  // Header-Customization pro Galerie
  // ---------------------------------------------------------------------------
  // Hero-Bild im Galerie-Header: entweder ein Bild AUS der Galerie
  // (heroFileId zeigt auf eine File-Row) ODER ein separater Upload
  // (heroUrl ist ein S3-Storage-Key, kein Public-URL). Beide gleichzeitig
  // ist nicht vorgesehen — UI lässt nur eines setzen, aber das Schema
  // verbietet es nicht hart, weil das Studio später beide haben dürfen
  // könnte (z.B. "Fallback wenn File gelöscht").
  heroFileId       String?  @db.Uuid
  heroUrl          String?  // S3-Key oder absolute URL (CDN), nullable
  
  // Optional Overlay-Farbe über dem Hero. Hex-RGBA-String wie "#00000066"
  // (alpha = 0x66 ~ 40%). Wenn null, kein Overlay. Wird im Frontend als
  // CSS background-color über das Hero-Bild gelegt.
  heroOverlayColor String?  @db.VarChar(9)
  
  // Hintergrund-Farbe wenn KEIN Hero-Bild gesetzt ist. Hex-String wie
  // "#0f172a". Default null → Frontend nutzt globale Surface-Farbe.
  heroBackgroundColor String? @db.VarChar(7)
  
  // Galerie-spezifisches Logo (Event-Logo, Monogramm, ...). S3-Key oder
  // absolute URL. Wird klein im Header über/neben dem Titel angezeigt.
  // UNABHÄNGIG vom Branding-Logo (das ist Studio-weit) — beide können
  // gleichzeitig vorhanden sein.
  eventLogoUrl     String?
  
  // Reich formatierter Welcome-Text. Markdown — gerendert im Customer-
  // Header unter Titel/Description. Wenn null, wird nur description
  // angezeigt (Plain-Text). Description bleibt für den Galerie-Listen-
  // Auftritt (Studio, Mail-Vorschau) erhalten — markdown ist NUR für
  // den Customer-View.
  welcomeMarkdown  String?
  
  // Hero-Layout-Variante. Bestimmt, wie der Customer-Header gerendert wird:
  //   "minimal"      — aktuelle Default-Ansicht, Text auf Backdrop (mit oder
  //                    ohne Hero-Bild)
  //   "splash"       — Vollbild-Hero, Titel zentriert, dezenter Scroll-Hint
  //   "side_by_side" — Editorial-Layout, Text links + Bild rechts
  //   "centered"     — Magazin-Style, Logo+Titel zentriert, Hero darunter klein
  // Default "minimal" → existierende Galerien sehen identisch aus.
  heroLayout       String   @default("minimal")
  
  // Grid-Layout-Variante für das File-Grid auf der Customer-Seite:
  //   "equal"     — alle Tiles exakt gleich (Quadrate). Default.
  //   "justified" — Reihen-basiert, Bilder einer Reihe gleich hoch
  //                 (flex-wrap + flex-grow Trick, kein JS-Layout).
  //
  // Historische Werte: "masonry" existierte als CSS-columns-Layout,
  // wurde aber entfernt weil es die Lese-Reihenfolge gegenüber der
  // Lightbox-Navigation kaputtmachte (Bilder spaltenweise gestapelt
  // statt zeilenweise). Die Migration setzt vorhandene
  // gridLayout='masonry' auf 'equal' um.
  gridLayout       String   @default("equal")
  
  // Slideshow-Übergangseffekt:
  //   "fade"    aktueller Default — Cross-Fade ~600ms zwischen Bildern
  //   "slide"   Bild slidet von rechts rein (350ms ease-out)
  //   "kenburns" langsamer Zoom + Pan auf jedem Bild (Slideshow-Klassiker)
  slideshowTransition String @default("fade")
  
  // Optional Hintergrund-Musik für die Slideshow. S3-Storage-Key
  // (z.B. "t/<tenant>/galleries/<gallery>/audio/bg-<rand>.mp3").
  // Spielt NUR im Slideshow-Modus, nicht im normalen Browse — der
  // Customer hat dort schon eine User-Geste gemacht (Slideshow-Start),
  // damit ist Auto-Play durch Browser-Policies erlaubt.
  // Loopt automatisch, Volume-Default 70 %, im Slideshow-UI per
  // Slider justierbar (clientseitig, nicht persistiert).
  slideshowAudioUrl String?
  
  // Galerie-spezifische Schriftarten — überschreiben die Branding-
  // Schriftart nur für diese Galerie. Beide Felder sind kurze IDs
  // aus einer kuratierten Liste (siehe lib/fonts.ts im Frontend),
  // KEINE freien Strings — das Frontend macht eine Lookup gegen die
  // Liste und ignoriert unbekannte Werte.
  //   fontHeading: für h1/h2 (Galerie-Titel, Markdown-Headings)
  //   fontBody:    für alles andere (Description, Welcome-Body, UI)
  // Beide null → Branding-Default gewinnt.
  fontHeading      String?  @db.VarChar(40)
  fontBody         String?  @db.VarChar(40)
  
  // Galerie-spezifisches Footer-Markdown. Wird am Ende der Customer-
  // Seite unterhalb des File-Grids gerendert. Typischerweise:
  // Dankeschön-Text, Kontaktdaten, Social-Media-Links. Wenn null wird
  // nur der Tenant-weite Branding-Footer gerendert (falls vorhanden).
  footerMarkdown   String?
  
  // Galerie-spezifische Farben — überschreiben die entsprechenden
  // Werte des Tenant-Brandings nur für diese eine Galerie.
  // - colorBackground: Surface-Canvas (Hauptfläche der Customer-Seite)
  //   Text auf diesem Hintergrund wird automatisch in den passenden
  //   Kontrast (hell oder dunkel) berechnet — kein separates Text-
  //   Color-Feld nötig.
  // - colorAccent: Akzent-Farbe (Buttons, Selection-Marker, Links)
  //   Auch hier wird die "Contrast"-Farbe (Text auf Akzent) automatisch
  //   berechnet.
  // Beide Hex-#RRGGBB.
  colorBackground  String? @db.VarChar(7)
  colorAccent      String? @db.VarChar(7)
  
  // Flexible Einstellungen (Sortierung, Layout, ...)
  settings        Json     @default("{}")
  
  files           File[]
  accessTokens    GalleryAccess[]
  uploadLinks     UploadLink[]
  downloadLogs    DownloadLog[]
  zipDownloads    ZipDownload[]
  tags            GalleryTag[]
  sections        GallerySection[]
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@index([tenantId])
  @@index([ownerId])
  @@index([slug])
  @@map("galleries")
}

// -----------------------------------------------------------------------------
// Galerie-Sections / Kapitel
// -----------------------------------------------------------------------------
// Optionales Gruppierungs-Layer für eine Galerie. Sections sind
// Kapitel wie "Vorbereitung", "Trauung", "Feier" für eine
// Hochzeitsgalerie. Files können einer Section zugeordnet werden;
// Files ohne Section bleiben im Default-Bucket und werden im Customer-
// View oberhalb der Sections gerendert.
//
// Sortierung über sortIndex (kleinster zuerst), nicht alphabetisch —
// das Studio entscheidet die Reihenfolge bewusst (chronologisch
// passend zum Event-Ablauf).
//
// Cover-Bild ist optional. Wenn gesetzt, zeigt der Section-Renderer
// im Customer-View ein größeres Banner mit dem Cover; sonst nur einen
// Titel-Trennbalken.
model GallerySection {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  galleryId   String   @db.Uuid
  gallery     Gallery  @relation(fields: [galleryId], references: [id], onDelete: Cascade)
  
  title       String   @db.VarChar(120)
  // Optional: Beschreibung als Plain-Text-Untertitel (kein Markdown
  // hier — Section-Beschreibungen sind kurz und einzeilig in der
  // Customer-Anzeige; Markdown wäre Overkill).
  description String?  @db.VarChar(400)
  
  // Cover-File: muss zur SELBEN Galerie gehören. Wenn das File
  // gelöscht wird, setzen wir das Cover zurück auf null (SetNull),
  // damit die Section bestehen bleibt.
  coverFileId String?  @db.Uuid
  
  sortIndex   Int      @default(0)
  
  files       File[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([galleryId, sortIndex])
  @@map("gallery_sections")
}

// -----------------------------------------------------------------------------
// ZIP Downloads (pre-built, gecacht in S3)
// -----------------------------------------------------------------------------
// Wenn ein Kunde "Alle herunterladen" klickt, baut der Worker eine ZIP-Datei
// und cached sie für 7 Tage. Erneute Anfragen geben den fertigen Link zurück.
// Pro Galerie + Auswahl-Set (oder NULL für "alle") ein Eintrag.
model ZipDownload {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  galleryId   String   @db.Uuid
  gallery     Gallery  @relation(fields: [galleryId], references: [id], onDelete: Cascade)
  
  // Wer hat ihn angefordert? Null = öffentlich (alle Files der Galerie).
  // Wenn gesetzt: spezifisch zur Auswahl dieses Access-Tokens.
  accessId    String?  @db.Uuid
  
  // Wenn diese ZIP nur eine Untermenge der Files enthält (z.B. die
  // gepickten), hashen wir die fileId-Liste, um Cache-Hits zu erkennen.
  // NULL = "alle Files der Galerie".
  fileIdsHash String?
  fileCount   Int
  
  // "original" oder "web" — bestimmt, welche Bytes in die ZIP gepackt
  // werden. Default "original" für Rückwärtskompatibilität — der Worker
  // bzw. ältere Einträge ohne explizite Wahl liefern Originals.
  variant     String   @default("original")
  
  status      String   @default("pending") // pending | building | ready | failed
  storageKey  String?  // wenn ready
  sizeBytes   BigInt?
  errorMessage String?
  
  // Wann der Kunde benachrichtigt wurde (Mail). Null = noch nicht.
  notifiedAt  DateTime?
  
  expiresAt   DateTime // 7 Tage nach Erstellung
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([galleryId, expiresAt])
  @@unique([galleryId, accessId, fileIdsHash, variant])
  @@map("zip_downloads")
}

// -----------------------------------------------------------------------------
// Galerie-Zugang (Tokens für Kunden)
// -----------------------------------------------------------------------------
model GalleryAccess {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  galleryId     String   @db.Uuid
  gallery       Gallery  @relation(fields: [galleryId], references: [id], onDelete: Cascade)
  
  token         String   @unique     // kryptografisch zufällig
  label         String   // z.B. "Brautpaar", "Agentur ABC", "Team Sales"
  email         String?  @db.Citext  // optional, für Notifications
  
  // Berechtigungen
  canDownload   Boolean  @default(true)
  canComment    Boolean  @default(true)
  canSelect     Boolean  @default(true)
  canSeeOthers  Boolean  @default(false) // sieht Kommentare/Auswahl anderer Teams?
  
  expiresAt     DateTime?
  lastAccessAt  DateTime?
  accessCount   Int      @default(0)
  
  // Wenn der Kunde explizit "Auswahl abschließen" geklickt hat
  finalizedAt   DateTime?
  
  selections    Selection[]
  comments      Comment[]
  
  createdAt     DateTime @default(now())
  
  @@index([galleryId])
  @@index([token])
  @@map("gallery_access")
}

// -----------------------------------------------------------------------------
// Upload-Links (öffentliche Drag-and-Drop Upload-Endpunkte pro Galerie)
// -----------------------------------------------------------------------------
// Erlaubt es dem Studio-Owner, einen Link zu erstellen den er an Dritte
// teilen kann ("Schick mir die Hochzeitsfotos vom Junggesellenabend").
// Empfänger landen auf einer minimalen Upload-Page (kein Login, ggf.
// Passwort), können Files reinziehen, sehen aber NICHTS von der
// Galerie selbst und auch nicht die Uploads anderer.
//
// Files die über einen UploadLink reinkommen werden mit
// File.uploadedVia='upload_link' und File.publicVisibility='hidden'
// gespeichert: Studio-User sieht sie sofort (mit Badge), Customer-
// Galerie zeigt sie erst nach manueller Freigabe.
model UploadLink {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  galleryId       String   @db.Uuid
  gallery         Gallery  @relation(fields: [galleryId], references: [id], onDelete: Cascade)

  // Kryptografisch zufälliger Token in der URL — analog GalleryAccess.token.
  // 32 Bytes (urlsafe base64 → ~43 Chars). Wird beim Erstellen einmal
  // generiert, nie geupdated.
  token           String   @unique
  label           String   // z.B. "Junggesellenabend Team Müller"

  // Optionales Passwort (bcrypt-Hash). Wenn null: kein Login-Step, der
  // Link allein reicht. Wenn gesetzt: Upload-Page zeigt eine Passwort-
  // Eingabe vor dem Drag-and-Drop.
  passwordHash    String?

  // Aktiv-Schalter — wenn false, gibt der Endpoint 403 zurück und die
  // Upload-Page zeigt "Link deaktiviert". Studio kann jederzeit
  // toggeln ohne den Link löschen zu müssen.
  active          Boolean  @default(true)

  // Limits — alle optional. Wenn null = kein Limit für diese Dimension.
  // Hard-Limit pro File greift IMMER (siehe config.MAX_FILE_SIZE_MIB),
  // diese Limits sind zusätzlich pro Link.
  maxFiles        Int?     // max Anzahl Files über DIESEN Link in Summe
  maxBytesTotal   BigInt?  // max Gesamt-Größe über DIESEN Link
  // Per-File-Limit für DIESEN Link in Bytes. Null = Tenant-Wert
  // erbt sich durch (tenant.maxUploadMib oder ENV-Default). Wenn
  // gesetzt: MUSS ≤ Tenant-Limit sein (Validierung im API). So
  // kann der Studio-User einen Link explizit auf "max 50 MB pro
  // File" setzen, z.B. für Smartphone-Schnappschüsse vom Gast.
  maxFileBytes    BigInt?

  // Ablauf-Datum — nach diesem Zeitpunkt 403. Null = kein Ablauf.
  expiresAt       DateTime?

  // Live-Statistik. Werden bei jedem erfolgreichen Upload aktualisiert.
  uploadCount     Int      @default(0)
  bytesUploaded   BigInt   @default(0)
  lastUploadAt    DateTime?

  // Files die über diesen Link reingekommen sind. SetNull bei Delete,
  // damit alte Files erhalten bleiben aber den Link-Bezug verlieren.
  files           File[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([galleryId])
  @@index([token])
  @@map("upload_links")
}

// -----------------------------------------------------------------------------
// Files & Renditions
// -----------------------------------------------------------------------------
model File {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  galleryId       String   @db.Uuid
  gallery         Gallery  @relation(fields: [galleryId], references: [id], onDelete: Cascade)
  
  originalFilename String
  storageKey      String   // Pfad im S3-Bucket
  mimeType        String
  sizeBytes       BigInt
  sha256          String?
  
  width           Int?
  height          Int?
  durationMs      Int?     // bei Videos
  
  // Kategorisierung
  kind            String   // image | raw | video | other
  
  // EXIF / Metadaten flexibel
  exif            Json?
  takenAt         DateTime?
  
  // Processing-Status
  status          String   @default("uploading") // uploading | processing | ready | failed
  errorMessage    String?
  
  sortIndex       Int      @default(0)
  
  // Hochlade-Quelle: wer hat das File hier reingeholt?
  //   "studio"      → Owner/Mitarbeiter über Studio-UI (Standard)
  //   "upload_link" → Dritte über einen UploadLink (mit Token)
  // Files mit uploadLinkId können vom Studio noch nicht-freigegeben
  // sein (publicVisibility='hidden') — dann sieht der Studio-User
  // sie mit Badge, der Customer aber noch nicht.
  uploadedVia     String   @default("studio") // "studio" | "upload_link"
  uploadLinkId    String?  @db.Uuid
  uploadLink      UploadLink? @relation(fields: [uploadLinkId], references: [id], onDelete: SetNull)

  // Customer-Sichtbarkeit. Bei studio-Uploads default "visible".
  // Bei upload_link default "hidden" — Studio sieht im Studio,
  // Customer-Galerie zeigt aber erst nach 'approve'.
  // "rejected" = Studio hat den Upload aktiv abgelehnt; S3-Objekte
  // wurden gelöscht (kein Thumb mehr, kein Original), DB-Row bleibt
  // für Audit + UI-Anzeige.
  publicVisibility String  @default("visible") // "visible" | "hidden" | "rejected"

  // Reject-Metadaten — gesetzt nur wenn publicVisibility="rejected".
  // Reason ist freitext (max 500), aus Preset-Optionen oder eigener
  // Eingabe. rejectedBy = User-ID des Studio-Owners der abgelehnt hat.
  rejectedAt      DateTime?
  rejectedBy      String?  @db.Uuid
  rejectedReason  String?

  // Optional einer Section/Kapitel zugeordnet. Null = File erscheint
  // im Default-Bucket der Galerie (Pre-Section-Verhalten). Section
  // gehört IMMER zur selben Galerie wie das File — wir prüfen das
  // anwendungsseitig (kein zusammengesetzter FK in Postgres).
  sectionId       String?  @db.Uuid
  section         GallerySection? @relation(fields: [sectionId], references: [id], onDelete: SetNull)
  
  renditions      Rendition[]
  selections      Selection[]
  comments        Comment[]
  downloadLogs    DownloadLog[]
  tags            FileTag[]
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@index([galleryId, sortIndex])
  @@index([galleryId, status])
  @@index([galleryId, publicVisibility])
  @@index([sha256])
  // Composite-Index fuer die Duplikat-Erkennung pro Galerie: die
  // Query `SELECT ... WHERE galleryId=? GROUP BY sha256 HAVING count>1`
  // landet damit auf einem reinen Index-Scan, ohne Heap-Lookup.
  @@index([galleryId, sha256])
  @@index([sectionId])
  @@index([uploadLinkId])
  @@map("files")
}

model Rendition {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  fileId      String   @db.Uuid
  file        File     @relation(fields: [fileId], references: [id], onDelete: Cascade)
  
  kind        String   // thumb | preview | web | watermarked | download | hls | poster | sprite
  storageKey  String
  format      String   // webp | avif | jpeg | mp4 | m3u8 | ...
  width       Int?
  height      Int?
  sizeBytes   BigInt
  // Rendition-spezifische Metadaten. Schema je nach kind:
  //   sprite: { interval: float, cols: int, rows: int,
  //             tileWidth: int, tileHeight: int, frames: int }
  metadata    Json?
  
  createdAt   DateTime @default(now())
  
  @@unique([fileId, kind])
  @@index([fileId])
  @@map("renditions")
}

// -----------------------------------------------------------------------------
// Proofing: Auswahl, Kommentare, Ratings
// -----------------------------------------------------------------------------
model Selection {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  fileId        String   @db.Uuid
  file          File     @relation(fields: [fileId], references: [id], onDelete: Cascade)
  
  accessId      String   @db.Uuid
  access        GalleryAccess @relation(fields: [accessId], references: [id], onDelete: Cascade)
  
  // Picdrop-Style Color-Tags
  color         String?  // red | yellow | green
  rating        Int?     // 1-5 Sterne
  liked         Boolean  @default(false)
  status        String?  // pick | reject | maybe
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  @@unique([fileId, accessId])
  @@index([fileId])
  @@index([accessId])
  @@map("selections")
}

model Comment {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  fileId        String   @db.Uuid
  file          File     @relation(fields: [fileId], references: [id], onDelete: Cascade)
  
  accessId      String?  @db.Uuid
  access        GalleryAccess? @relation(fields: [accessId], references: [id], onDelete: Cascade)
  
  authorLabel   String   // "Anna (Brautpaar)" oder "Studio"
  authorIsStudio Boolean @default(false)
  
  body          String
  // Scribbles als SVG-Pfad-Daten / Punkte (für Annotationen direkt auf Bild)
  annotation    Json?
  
  parentId      String?  @db.Uuid
  parent        Comment? @relation("CommentThread", fields: [parentId], references: [id], onDelete: Cascade)
  replies       Comment[] @relation("CommentThread")
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  @@index([fileId])
  @@index([accessId])
  @@map("comments")
}

// -----------------------------------------------------------------------------
// Download-Log (Audit)
// -----------------------------------------------------------------------------
model DownloadLog {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  galleryId   String   @db.Uuid
  gallery     Gallery  @relation(fields: [galleryId], references: [id], onDelete: Cascade)
  
  fileId      String?  @db.Uuid
  file        File?    @relation(fields: [fileId], references: [id], onDelete: SetNull)
  
  kind        String   // single | zip | rendition
  ipAddress   String?
  userAgent   String?
  bytes       BigInt?
  
  createdAt   DateTime @default(now())
  
  @@index([galleryId, createdAt])
  @@map("download_logs")
}

// -----------------------------------------------------------------------------
// Generischer Event-Log (Audit)
// -----------------------------------------------------------------------------
model Event {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  // Tenant-Kontext eines Events. Bei Super-Admin-Aktionen ohne Tenant-Bezug
  // (Login/Logout) ist das null; bei Aktionen gegen einen Tenant
  // (suspend/archive/owner-invite) wird der Ziel-Tenant gesetzt — damit
  // bleibt das Audit-Log eines Tenants chronologisch vollständig.
  tenantId    String?  @db.Uuid
  tenant      Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  actorType   String   // user | access | system
  actorId     String?
  action      String   // login | gallery.create | file.delete | share.create | ...
  targetType  String?
  targetId    String?
  payload     Json?
  ipAddress   String?
  
  createdAt   DateTime @default(now())
  
  @@index([tenantId, createdAt])
  @@index([tenantId, action])
  @@map("events")
}

// -----------------------------------------------------------------------------
// Billing (nur im Hosted Mode aktiv)
// -----------------------------------------------------------------------------
// Plan-Definitionen für Self-Hosting komplett deaktivierbar via BILLING_ENABLED=false.
// Im Hosted-Modus mit BILLING_ENABLED=true werden Limits durchgesetzt.

model BillingPlan {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug            String   @unique // free | starter | pro | studio | custom
  name            String
  description     String?
  
  // Limits (null = unbegrenzt)
  storageGib      Int?     // Speicher in GiB
  galleriesMax    Int?     // max Anzahl aktiver Galerien
  filesPerGallery Int?     // max Files pro Galerie
  usersMax        Int?     // max Studio-Mitglieder
  bandwidthGibPerMonth Int? // Traffic-Limit
  
  // Feature-Gates
  customDomain    Boolean  @default(false)
  whiteLabel      Boolean  @default(false)
  watermarking    Boolean  @default(true)
  analytics       Boolean  @default(false)
  
  // Stripe-Integration
  stripePriceIdMonthly String?
  stripePriceIdYearly  String?
  priceMonthlyCents    Int?
  priceYearlyCents     Int?
  currency             String  @default("EUR")
  
  isActive        Boolean  @default(true)
  sortOrder       Int      @default(0)
  
  subscriptions   BillingSubscription[]
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@map("billing_plans")
}

model BillingSubscription {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId           String   @unique @db.Uuid
  tenant             Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  planId             String   @db.Uuid
  plan               BillingPlan @relation(fields: [planId], references: [id])
  
  status             String   // trialing | active | past_due | canceled | unpaid
  billingInterval    String   // monthly | yearly
  
  // Stripe
  stripeCustomerId   String?
  stripeSubscriptionId String? @unique

  // Subscription-Item-IDs — jedes Stripe-Subscription-Item entspricht
  // einer Price (Plan oder Storage-Pack). Wir tracken sie separat,
  // damit Webhook-Updates und Storage-Pack-Quantity-Changes gezielt
  // das richtige Item updaten können (POST /subscription_items/<id>).
  stripePlanItemId         String?
  stripeStorageAddonItemId String?
  
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  cancelAtPeriodEnd  Boolean  @default(false)
  trialEndsAt        DateTime?
  
  // Aktuelle Nutzung (wird vom Worker periodisch geupdatet)
  storageBytesUsed   BigInt   @default(0)
  bandwidthBytesUsed BigInt   @default(0)  // monatlich, wird zurückgesetzt
  galleriesCount     Int      @default(0)

  // Zusätzlich zum Plan-Speicher gekaufte 50-GiB-Packs. Wird in
  // Sprint 2 vom Stripe-Webhook gepflegt (eines pro gekauftem
  // Storage-Pack-Subscription-Item).
  storageAddonGib    Int      @default(0)

  // Karenz-Tracking: gesetzt wenn die Subscription past_due geblieben
  // ist und der Tenant auf read-only-Modus eskaliert wurde. Wird beim
  // erfolgreichen Payment wieder auf null gesetzt.
  readOnlySince      DateTime?
  
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  
  @@map("billing_subscriptions")
}

// Einzelne Abrechnungspositionen für überzogene Nutzung (Usage-based Billing)
model BillingUsageRecord {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String   @db.Uuid
  
  kind        String   // storage_overage | bandwidth_overage | extra_user
  quantity    BigInt   // Einheit je nach kind (Bytes, Anzahl, ...)
  unitPriceCents Int
  periodStart DateTime
  periodEnd   DateTime
  
  reportedToStripeAt DateTime?
  
  createdAt   DateTime @default(now())
  
  @@index([tenantId, periodStart])
  @@map("billing_usage_records")
}

// -----------------------------------------------------------------------------
// Stripe-Webhook-Events: Dedup + Audit-Trail
// -----------------------------------------------------------------------------
// Stripe garantiert at-least-once delivery für Webhooks. Bei Network-Flakes
// oder unserem 5xx kommt derselbe Event mehrfach an. Wir tracken die
// Event-IDs hier und skippen duplicates beim Worker-Processing.
//
// Plus: ein Auditing-Trail, wer wann welchen Webhook empfangen hat. Wichtig
// für Debugging ("warum ist die Subscription auf past_due gegangen?").
//
// Lifecycle:
//   1. POST /billing/webhook empfängt Event, prüft Signatur, schreibt
//      Row mit status='received', enqueued Job in Redis-Stream.
//   2. Stripe-Worker holt Job, processed Event-Body, updated Subscription/
//      Tenant-Felder. Setzt status='processed' (oder 'failed' bei Error).
//   3. Doppelter Receive: API prüft existing Row, skippt enqueue.
model StripeWebhookEvent {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  // Stripe's Event-ID (z.B. "evt_1234abcd"). Unique-Constraint sorgt
  // für Dedup: bei doppeltem Receive würde der INSERT fehlschlagen,
  // wir fangen den unique-conflict ab und skippen.
  stripeEventId String @unique

  // Event-Type ("customer.subscription.updated", "invoice.paid", etc.)
  type        String

  // Roher Event-Body (JSON) — der Worker arbeitet damit. Bei
  // großen Events (z.B. Invoice mit vielen Items) sind das ~5-50 KB.
  payload     Json

  // "received" → enqueued → "processed" / "failed"
  status      String   @default("received")
  errorMessage String?

  // Beziehungs-Felder: bei welchem Tenant ist das angekommen?
  // Können auch null sein, wenn der Event vor dem Customer-Mapping
  // ankommt (z.B. checkout.session.completed bevor wir die customer-
  // id zum Tenant gemappt haben).
  tenantId    String?  @db.Uuid

  createdAt   DateTime @default(now())
  processedAt DateTime?

  @@index([tenantId, createdAt])
  @@index([type, createdAt])
  @@index([status, createdAt])
  @@map("stripe_webhook_events")
}

// -----------------------------------------------------------------------------
// Webhooks (Outbound)
// -----------------------------------------------------------------------------
// Pro Tenant können Studio-User HTTP-Endpunkte hinterlegen, die bei
// bestimmten Events (gallery.created, selection.finalized, ...) aufgerufen
// werden. Damit lassen sich Workflows in Zapier, n8n, eigenen Webhook-
// Receivern oder direkt im Studio-CRM anstoßen, ohne dass Lumio die
// jeweilige Integration selbst kennen muss.
//
// Signatur: jeder Request bekommt einen `X-Lumio-Signature` Header mit
// HMAC-SHA256(secret, timestamp + "." + body) und `X-Lumio-Timestamp`.
// Empfänger verifizieren das wie bei Stripe/GitHub. Das Secret wird beim
// Anlegen einmal angezeigt und ist danach (gehashed) nur noch zur
// Signatur-Erzeugung im API-Code verfügbar — UI rendert es nicht mehr.
//
// Auslieferung: nicht synchron im Request-Pfad! Der Aufrufer publiziert
// nur in einen Redis-Stream; ein Worker macht den HTTP-POST mit Retries.
// Sonst würde ein langsamer/down Webhook-Empfänger Studio-Operationen
// verzögern oder fehlschlagen lassen.
//
// Events ist ein String-Array — wir validieren auf Anwendungsebene gegen
// eine Whitelist, nicht via DB-Enum, damit das Hinzufügen neuer Events
// keine Migration braucht.
model Webhook {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String   @db.Uuid
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  label       String   // freie Bezeichnung im Studio, z.B. "Zapier Hochzeit"
  url         String   // muss https sein (keine Plain-HTTP-Auslieferungen
                       // in Produktion — Signatur-Headers sind sonst sinnlos)
  secret      String   // wird mit dem Body signiert (HMAC-SHA256)
  events      String[] // Whitelist subscriebter Events
  active      Boolean  @default(true)
  
  // Stats für die Studio-UI
  lastDeliveryAt   DateTime?
  lastDeliveryOk   Boolean?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  deliveries  WebhookDelivery[]
  
  @@index([tenantId])
  @@map("webhooks")
}

// Audit-Log der versuchten Auslieferungen.
// Wir behalten alle Deliveries (auch erfolgreiche) für eine begrenzte
// Frist, damit das Studio bei Debug-Fragen ("warum hat Zapier den Job
// nicht gestartet?") nachschauen kann. Aufräumen: Cron-Job, der ältere
// als 30 Tage entfernt — verfasst, wenn das Volumen das nötig macht.
model WebhookDelivery {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  webhookId   String   @db.Uuid
  webhook     Webhook  @relation(fields: [webhookId], references: [id], onDelete: Cascade)
  
  eventType   String   // z.B. "gallery.created"
  payload     Json     // das, was wir als Body gepostet haben
  
  // Status der Auslieferung
  status      String   // pending | sent | failed | dead
  httpStatus  Int?     // HTTP-Status-Code der Antwort
  errorMessage String?
  
  // Retry-Verwaltung
  attempts    Int      @default(0)
  nextAttemptAt DateTime?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([webhookId, createdAt])
  @@index([status, nextAttemptAt])
  @@map("webhook_deliveries")
}

// -----------------------------------------------------------------------------
// Tags
// -----------------------------------------------------------------------------
// Hierarchisches Label-System pro Tenant. Tags lassen sich an Galleries
// und Files heften und im Studio zum Filtern verwenden. Hierarchie über
// parentId — ein Tag kann ein anderes als Parent haben, was die UI als
// breadcrumb ("Event / Hochzeit") darstellt. DB-seitig kein cycle-check;
// das Erstellungs-Endpoint validiert das.
//
// name ist innerhalb desselben Parent unique (case-insensitive auf
// Application-Seite — DB-collation würden wir extra konfigurieren
// müssen, lohnt nicht).
//
// color als HEX-String ("#RRGGBB"). Wir validieren das Format auf
// API-Seite; DB nimmt jeden String.
//
// onDelete: Cascade auf den Joins, damit ein gelöschter Tag automatisch
// aus allen Galerien/Files verschwindet.
model Tag {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String   @db.Uuid
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  name        String
  color       String   @default("#94a3b8")  // slate-400 als neutraler default
  parentId    String?  @db.Uuid
  parent      Tag?     @relation("TagHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children    Tag[]    @relation("TagHierarchy")
  
  galleries   GalleryTag[]
  files       FileTag[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([tenantId])
  @@index([tenantId, parentId])
  @@map("tags")
}

// Many-to-Many: Gallery ↔ Tag
// Wir nutzen kein Prisma-implizites "@relation(...)" mit doppelseitigen
// arrays, sondern eine explizite Join-Tabelle. Das macht Inserts/Deletes
// klarer und gibt uns optional ein createdAt für "wann wurde das Tag
// gesetzt" — nice für Audit, kostet nichts.
model GalleryTag {
  galleryId   String   @db.Uuid
  tagId       String   @db.Uuid
  gallery     Gallery  @relation(fields: [galleryId], references: [id], onDelete: Cascade)
  tag         Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  
  @@id([galleryId, tagId])
  @@index([tagId])
  @@map("gallery_tags")
}

// Many-to-Many: File ↔ Tag
model FileTag {
  fileId      String   @db.Uuid
  tagId       String   @db.Uuid
  file        File     @relation(fields: [fileId], references: [id], onDelete: Cascade)
  tag         Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  
  @@id([fileId, tagId])
  @@index([tagId])
  @@map("file_tags")
}

// -----------------------------------------------------------------------------
// Super-Admin & Tenant-Verwaltung
// -----------------------------------------------------------------------------
// Eigene Identität, getrennt von den per-Tenant-Usern (users). Begründung:
//   - Klare Trennung von Cross-Tenant-Operationen vs. Tenant-internem Studio
//   - Eigener Session-Cookie (lumio_super_session) — verhindert dass ein
//     Studio-Login versehentlich einen Super-Admin im selben Browser
//     öffnet oder umgekehrt
//   - Eigene Audit-Spur (in Event-Tabelle eventType="super.*")
//   - Owner-/Member-Rollen aus users sind bewusst nicht überladen — Super-
//     Admin ist KEIN Tenant-User, sondern ein Plattform-Operator.
model SuperAdmin {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email        String   @unique
  passwordHash String
  displayName  String
  
  // Wann zuletzt eingeloggt? Reine Anzeige im Self-Service-Bereich.
  lastLoginAt  DateTime?
  
  sessions     SuperAdminSession[]
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  @@map("super_admins")
}

// Setup-Token für initiale Passwort-Wahl beim Onboarding eines Tenant-Owners.
// Beim Anlegen eines Tenant-Owners durch den Super-Admin entsteht ein Token
// dieser Tabelle. Der Owner bekommt eine Mail mit Link
// /auth/setup-password?token=<token> und setzt darüber sein Passwort.
//
// Auch nutzbar für späteren "Passwort vergessen"-Flow — gleiche Tabelle,
// gleicher Token-Lebenszyklus, andere kind-Werte.
model PasswordResetToken {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String   @db.Uuid
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Hash des Tokens (nicht der Token selbst). Wir geben den Klartext-Token
  // an die Mail, speichern aber nur den Hash — falls die DB leaked, sind
  // die Tokens nicht direkt verwendbar.
  tokenHash   String   @unique
  
  // "setup" = initiales Passwort beim Onboarding
  // "reset" = vergessenes Passwort (späteres Feature)
  kind        String   @default("setup")
  
  expiresAt   DateTime
  usedAt      DateTime?
  
  createdAt   DateTime @default(now())
  
  @@index([userId, kind])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

// Eigene Session-Tabelle für Super-Admins. Begründung wie bei der eigenen
// SuperAdmin-Tabelle: Trennung von Plattform-Operator vs. Tenant-User.
// Die Sessions-Logik (Hash-only-Storage, 30d TTL, IP/UA-Tracking) ist
// identisch zur normalen Session-Tabelle.
model SuperAdminSession {
  id           String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  superAdminId String     @db.Uuid
  superAdmin   SuperAdmin @relation(fields: [superAdminId], references: [id], onDelete: Cascade)
  
  tokenHash    String     @unique
  ipAddress    String?
  userAgent    String?
  
  expiresAt    DateTime
  createdAt    DateTime   @default(now())
  
  @@index([superAdminId])
  @@index([expiresAt])
  @@map("super_admin_sessions")
}

// -----------------------------------------------------------------------------
// Smart Collections — gespeicherte Filter-Macros über die Galerien-Liste
// -----------------------------------------------------------------------------
// "Wie Lightroom Smart Collections" — der User kann einen Filter-Set
// (Mode + Status + Tags + Datums-Range) unter einem Namen speichern und
// später aus der Sidebar wieder aufrufen. Die Collection ändert keine
// Daten, sie ist eine reine Such-Hilfe.
//
// Filter-Definition liegt in einem JSON-Feld, damit wir später File-Level-
// Filter (Kind, Likes, etc.) dazupacken können ohne Migration. Das aktuelle
// MVP-Schema ist in apps/api/src/services/smart-collection-filter.ts
// dokumentiert und validiert (Zod).
//
// Sortierung in der Sidebar via sortOrder; per Studio-UI änderbar
// (Drag & Drop).
model SmartCollection {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String   @db.Uuid
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  // Sichtbar nur für den Ersteller. Falls wir später Team-Sharing wollen
  // (z.B. ownerScope='tenant'), bauen wir das als separate Spalte dazu.
  ownerId     String   @db.Uuid
  owner       User     @relation("SmartCollectionOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  
  name        String   // "Hochzeiten 2025 mit offener Auswahl"
  icon        String?  // optional emoji oder lucide-icon-key
  filter      Json     // siehe smart-collection-filter.ts Schema
  sortOrder   Int      @default(0)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([tenantId, ownerId])
  @@map("smart_collections")
}

// -----------------------------------------------------------------------------
// Tenant-Export (Datenexport für DSGVO / Pre-Delete-Backup / Self-Service)
// -----------------------------------------------------------------------------
// Ein TenantExport gruppiert mehrere Galerie-ZIPs. Der Trigger kann sein:
//   - Studio-User exportiert einzelne Galerie ("source = studio")
//   - Studio-User exportiert alle Galerien ("source = studio_all")
//   - Super-Admin exportiert für Tenant ("source = super_admin")
//
// Pro Galerie wird ein eigener ZIP-Build-Job ausgelöst (TenantExportItem).
// So skaliert das auch bei großen Tenants mit 200+ Galerien — die
// Browser-Downloads sind separat, parallel möglich, und ein einzelner
// fehlgeschlagener Build sprengt nicht das ganze Bundle.
//
// Bei source='super_admin' im Archive-Karenz-Zeitraum: Optional wird ein
// ExportToken generiert. Tenant kann ohne Login per Mail-Link runterladen.
model TenantExport {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String   @db.Uuid
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Wer hat den Export angefordert (Audit + UI).
  //   studio       = einzelne Galerie aus dem Studio
  //   studio_all   = alle Galerien aus dem Studio (Studio-Bulk-Export)
  //   super_admin  = Super-Admin (z.B. vor Hard-Delete)
  source      String

  // Status:
  //   pending  = Items werden erstellt, Worker enqueued
  //   building = mindestens ein Item baut noch
  //   ready    = alle Items haben einen Endzustand (ready oder failed)
  //   expired  = Ablauffrist erreicht, Files in S3 sind weg
  status      String   @default("pending")

  // Optional: User-ID des auslösenden Studio-Users. Bei super_admin null.
  triggeredByUserId String?  @db.Uuid

  // Optional: Super-Admin-ID. Bei studio-Trigger null.
  triggeredBySuperAdminId String? @db.Uuid

  // Wenn gesetzt: Token-basierter Download für Tenant ohne Login möglich.
  // Wird nur bei super_admin-Triggers für archived Tenants gesetzt.
  token       ExportToken?

  items       TenantExportItem[]

  // 30 Tage nach Erstellung. Cleanup-Job entfernt expired Exports.
  expiresAt   DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId, createdAt])
  @@index([expiresAt])
  @@map("tenant_exports")
}

// Pro Galerie ein ZIP-Item.
model TenantExportItem {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  exportId    String   @db.Uuid
  export      TenantExport @relation(fields: [exportId], references: [id], onDelete: Cascade)

  galleryId   String?  @db.Uuid  // null wenn Galerie inzwischen gelöscht
  // Wir snapshotten Galerie-Name + Slug, damit nach Gallery-Delete
  // im Export-Ordner trotzdem ein sinnvoller Name steht.
  gallerySlug String
  galleryName String

  status      String   @default("pending") // pending | building | ready | failed
  storageKey  String?
  sizeBytes   BigInt?
  fileCount   Int?
  errorMessage String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([exportId])
  @@map("tenant_export_items")
}

// Token-basierter Download-Zugang für archived Tenants (Use Case A).
// Eine Reihe pro Export, optional. Token wird in der Mail an den
// Tenant-Owner verschickt; öffnet ohne Login eine Download-Seite.
model ExportToken {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  exportId    String   @unique @db.Uuid
  export      TenantExport @relation(fields: [exportId], references: [id], onDelete: Cascade)

  // Random String, lang genug für Sicherheit gegen Brute-Force.
  // 32 Bytes base64url ≈ 43 Chars.
  token       String   @unique

  // Wenn gesetzt: Token wurde bereits einmal verwendet (z.B. wenn wir
  // mal einmalige Tokens machen wollen). Aktuell unbegrenzte Nutzung
  // bis expiresAt, das Feld ist nur für Audit/Forensik.
  firstAccessAt DateTime?
  accessCount   Int      @default(0)

  expiresAt   DateTime
  createdAt   DateTime @default(now())

  @@map("export_tokens")
}
