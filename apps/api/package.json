{
  "name": "@lumio/api",
  "version": "0.14.7",
  "private": true,
  "description": "Lumio API server — Fastify + TypeScript",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "lint": "eslint src",
    "test": "vitest run",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "create-admin": "node dist/scripts/create-admin.js",
    "create-admin:dev": "tsx src/scripts/create-admin.ts",
    "create-super-admin": "node dist/scripts/create-super-admin.js",
    "create-super-admin:dev": "tsx src/scripts/create-super-admin.ts",
    "stripe-bootstrap": "node dist/scripts/stripe-bootstrap.js",
    "stripe-bootstrap:dev": "tsx src/scripts/stripe-bootstrap.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.658.0",
    "@aws-sdk/s3-request-presigner": "^3.658.0",
    "@fastify/cookie": "^9.4.0",
    "@fastify/cors": "^9.0.1",
    "@fastify/jwt": "^9.0.1",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/sensible": "^5.6.0",
    "@fastify/websocket": "^10.0.1",
    "@prisma/client": "^5.22.0",
    "@simplewebauthn/server": "^11.0.0",
    "archiver": "^7.0.1",
    "argon2": "^0.41.1",
    "fastify": "^4.28.1",
    "fastify-plugin": "^4.5.1",
    "ioredis": "^5.4.1",
    "marked": "^18.0.4",
    "nodemailer": "^6.9.16",
    "otplib": "^13.4.0",
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0",
    "qrcode": "^1.5.4",
    "stripe": "^18.5.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/archiver": "^6.0.3",
    "@types/node": "^22.7.4",
    "@types/nodemailer": "^6.4.16",
    "@types/qrcode": "^1.5.5",
    "prisma": "^5.22.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "vitest": "^2.1.2"
  }
}
