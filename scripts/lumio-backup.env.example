# /etc/lumio-backup.env — Konfiguration für lumio-backup.sh + lumio-media-sync.sh
#
# WICHTIG: Diese Datei lebt NUR auf dem Server und enthält Secrets.
#          NIEMALS ins Git! Kopiere sie nach /etc/lumio-backup.env und
#          setze chmod 600. Siehe docs/BACKUP.md für das volle Setup.

# --- Allgemein ---
LUMIO_DIR=/opt/docker/lumio/lumio
STATUS_FILE=/backup/lumio/status.txt

# --- Postgres (Defaults passen für das Standard-Setup) ---
PG_SERVICE=postgres
PG_USER=lumio
PG_DB=lumio

# --- restic: EIN Passwort für BEIDE Repos ---
# Erzeugen: openssl rand -base64 48
# Dieses Passwort ist der EINZIGE Weg, die Backups zu entschlüsseln.
# Verlierst du es, ist das Backup tot. In den Passwort-Manager (anderes Gerät)!
RESTIC_PASSWORD_FILE=/root/.lumio-restic-pwd

# --- Repo 1: Hetzner Object Storage (ZWEITER Bucket, NICHT lumio-prod!) ---
HETZNER_S3_KEY=__HETZNER_BACKUP_BUCKET_KEY__
HETZNER_S3_SECRET=__HETZNER_BACKUP_BUCKET_SECRET__
HETZNER_RESTIC_REPO=s3:https://fsn1.your-objectstorage.com/lumio-backups/db

# --- Repo 2: Backblaze B2 (anderer Provider → überlebt Hetzner-Ausfall) ---
B2_KEY_ID=__B2_KEY_ID__
B2_APP_KEY=__B2_APP_KEY__
B2_RESTIC_REPO=b2:lumio-db-backup:db

# --- Aufbewahrung (Rotation) ---
KEEP_DAILY=7
KEEP_WEEKLY=4
KEEP_MONTHLY=6

# --- rclone (Bilder/Videos: lumio-prod → B2) ---
RCLONE_SRC=hetzner:lumio-prod
RCLONE_DST=b2:lumio-media-backup
RCLONE_BWLIMIT=50M
# Status-Datei des Media-Syncs für die Super-Admin-Ampel. Muss im selben
# (in den API-Container gemounteten) Verzeichnis liegen wie STATUS_FILE.
MEDIA_STATUS_FILE=/backup/lumio/media-status.txt

# --- Dead-Man's-Switch (healthchecks.io o.ä.). Leer lassen = aus. ---
# Lege je einen Check an und trage die Ping-URL ein. Das Skript pingt
# /start, Erfolg (Basis-URL) und /fail — schlägt der Cron stumm fehl,
# alarmiert dich der Dienst.
HEALTHCHECK_URL=
MEDIA_HEALTHCHECK_URL=
