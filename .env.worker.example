# =============================================================================
# Lumio Worker-Node — .env.worker (Vorlage)
# =============================================================================
# Kopieren nach .env.worker auf dem Worker-Server und ausfüllen.
# Die privaten IPs stammen aus dem Hetzner Private Network.

# --- Verbindung zum Haupt-Server (PRIVATE IP, nicht öffentlich!) ---
# Postgres: gleiche Credentials wie auf dem Haupt-Server, aber Host = private IP
DATABASE_URL=postgres://lumio:DEIN_DB_PASSWORT@10.0.0.2:5432/lumio

# Redis: mit Passwort (siehe REDIS_PASSWORD auf dem Haupt-Server)
REDIS_URL=redis://:DEIN_REDIS_PASSWORT@10.0.0.2:6379

# --- S3 / Hetzner Object Storage (identisch zum Haupt-Server) ---
STORAGE_PROVIDER=s3
S3_ENDPOINT=https://fsn1.your-objectstorage.com
S3_REGION=fsn1
S3_BUCKET=lumio-prod
S3_ACCESS_KEY=DEIN_S3_ACCESS_KEY
S3_SECRET_KEY=DEIN_S3_SECRET_KEY
S3_FORCE_PATH_STYLE=true

# --- Worker-Tuning ---
# Faustregel: ungefähr Anzahl CPU-Kerne. 12-vCPU-Server → 10.
WORKER_CONCURRENCY=10
LOG_LEVEL=info
