# =============================================================================
# Lumio — Environment Configuration
# =============================================================================
# Kopiere diese Datei nach `.env` und passe die Werte an.
# NIEMALS .env in git committen.

# -----------------------------------------------------------------------------
# Deployment Mode
# -----------------------------------------------------------------------------
# single   = eine Instanz für ein einzelnes Studio (Multi-Tenant deaktiviert)
# multi    = mehrere Studios/Tenants auf einer Instanz (für SaaS / Hosted Mode)
DEPLOYMENT_MODE=single

# -----------------------------------------------------------------------------
# Public Endpoint
# -----------------------------------------------------------------------------
# DAS ist die EINE App-Adresse, unter der Lumio von außen erreichbar ist.
# Caddy hört darauf, alle anderen URLs werden daraus abgeleitet.
#
# Beispiele:
#   LUMIO_HOST=                              → kein spezifischer Hauptdomain-
#                                              Block (Catch-All bedient alles
#                                              auf Port 80). Empfohlen für
#                                              lokales Dev und für Production
#                                              hinter externem Reverse-Proxy
#                                              mit Custom-Domain-Support.
#   LUMIO_HOST=galerien.example.com          → eigener Block für die Domain;
#                                              wenn Caddy direkt aus dem
#                                              Internet erreichbar ist, holt
#                                              er automatisch ein Let's-
#                                              Encrypt-Cert für HTTPS.
#   LUMIO_HOST=http://galerien.example.com   → nur HTTP, kein Cert (hinter
#                                              externem Reverse-Proxy).
#
# WICHTIG: NICHT `:80` setzen wenn Custom-Domains aktiviert werden sollen —
# das kollidiert mit dem http://-Catch-All-Block, der die Custom-Domains
# bedient (siehe infra/caddy/Caddyfile).
LUMIO_HOST=

# PUBLIC_URL wird in E-Mails, Galerie-Share-Links und für CORS verwendet.
# Muss zur LUMIO_HOST-Konfiguration passen — bei einem Domain-Setup:
#   PUBLIC_URL=https://galerien.example.com
# Bei lokalem Setup auf Default-Ports einfach so lassen.
PUBLIC_URL=http://localhost

# -----------------------------------------------------------------------------
# S3 / MinIO Public Endpoint
# -----------------------------------------------------------------------------
# Browser laden Bilder/Logos direkt von S3 (über presigned URLs). Dafür braucht
# MinIO einen Hostname, den der Browser erreichen kann — der interne
# Docker-Container-Name 'minio' funktioniert nicht.
#
# MinIO unterstützt KEIN Path-Präfix-Rewriting wegen V4-Signatur, deshalb
# muss S3 auf einem eigenen Hostname laufen — typischerweise eine Subdomain.
#
# Beispiele:
#   LUMIO_S3_HOST=:81                  → lokal: localhost:81 (über CADDY_HTTP_PORT
#                                        gemappt) für Tests
#   LUMIO_S3_HOST=s3.galerien.example.com  → eigene Subdomain mit Auto-HTTPS
#   LUMIO_S3_HOST=http://s3.galerien.example.com → nur HTTP, hinter externem Proxy
#
# S3_PUBLIC_URL ist die Adresse, die in presigned URLs landet. Muss zur
# LUMIO_S3_HOST-Konfiguration passen.
LUMIO_S3_HOST=:81
S3_PUBLIC_URL=

# -----------------------------------------------------------------------------
# Host-Ports (Mapping vom Container nach außen)
# -----------------------------------------------------------------------------
# Anpassen, wenn die Default-Ports auf dem Host schon belegt sind. Caddy ist
# der einzige Container, der wirklich öffentlich erreichbar sein muss; FRONTEND
# und API werden auf 127.0.0.1 gebunden (nur lokal zum Debuggen). Selbst dann
# muss die jeweilige Port-Nummer auf dem Host komplett frei sein — der Linux-
# Kernel reserviert Ports adressunabhängig, ein anderer Service auf 0.0.0.0:3000
# blockiert auch ein 127.0.0.1:3000-Binding.
CADDY_HTTP_PORT=80
CADDY_HTTPS_PORT=443
FRONTEND_PORT=3000
API_PORT=3001
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# -----------------------------------------------------------------------------
# Database (Postgres)
# -----------------------------------------------------------------------------
POSTGRES_DB=lumio
POSTGRES_USER=lumio
POSTGRES_PASSWORD=changeme_use_a_long_random_string
# Wird automatisch aus den obigen drei Werten gebaut, kannst aber überschreiben:
# DATABASE_URL=postgres://lumio:changeme@postgres:5432/lumio

# -----------------------------------------------------------------------------
# Redis (Queue + Cache + Sessions)
# -----------------------------------------------------------------------------
REDIS_URL=redis://redis:6379

# -----------------------------------------------------------------------------
# Object Storage (S3-kompatibel)
# -----------------------------------------------------------------------------
# Mögliche Werte für STORAGE_PROVIDER:
#   minio       = lokales MinIO (Standard für Self-Hosting)
#   s3          = AWS S3
#   r2          = Cloudflare R2
#   b2          = Backblaze B2
#   wasabi      = Wasabi
#   custom      = beliebiges S3-kompatibles Backend (z.B. Hetzner Object Storage)
STORAGE_PROVIDER=minio

# Endpoint:
#   - MinIO lokal:    http://minio:9000
#   - AWS S3:         https://s3.<region>.amazonaws.com  (oder leer, dann auto)
#   - Cloudflare R2:  https://<account_id>.r2.cloudflarestorage.com
#   - Backblaze B2:   https://s3.<region>.backblazeb2.com
#   - Wasabi:         https://s3.<region>.wasabisys.com
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_BUCKET=lumio
S3_ACCESS_KEY=changeme_access_key
S3_SECRET_KEY=changeme_secret_key
# Path-Style nur für MinIO/manche kompatible Anbieter (true), AWS/R2: false
S3_FORCE_PATH_STYLE=true
# Public CDN-URL für Renditions (optional). Wenn gesetzt, werden Browser-URLs
# darauf umgeschrieben statt direkt auf S3 zu zeigen. Hilfreich mit Cloudflare CDN
# vor R2 oder mit eigenem Reverse-Proxy.
# S3_PUBLIC_URL=https://cdn.example.com

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
# 32+ zufällige Bytes. Generieren z.B. mit: openssl rand -base64 32
JWT_SECRET=changeme_at_least_32_random_chars_pls
SESSION_SECRET=changeme_at_least_32_random_chars_pls
# Argon2 Memory in KiB (Empfehlung: 19456 = 19 MiB)
ARGON2_MEMORY_KIB=19456

# -----------------------------------------------------------------------------
# Mail (für Notifications, Einladungen, Passwort-Reset)
# -----------------------------------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="Lumio <noreply@example.com>"
SMTP_SECURE=false

# -----------------------------------------------------------------------------
# Limits & Upload-Konfiguration
# -----------------------------------------------------------------------------
# Max Größe eines einzelnen Files in MiB (RAW kann groß werden!)
MAX_FILE_SIZE_MIB=2048
# Max parallele Worker-Jobs pro Worker-Container
WORKER_CONCURRENCY=4
# Chunk-Größe für Multipart-Uploads (S3 Default: 5 MiB Minimum)
UPLOAD_CHUNK_SIZE_MIB=8

# -----------------------------------------------------------------------------
# Billing (nur im Hosted Mode mit DEPLOYMENT_MODE=multi relevant)
# -----------------------------------------------------------------------------
# Aktiviert das Abrechnungsmodul. Wenn false, sind alle Features für alle Tenants
# unbegrenzt verfügbar (typisch für Self-Hosting mit DEPLOYMENT_MODE=single).
BILLING_ENABLED=false
# Stripe-Keys (nur wenn BILLING_ENABLED=true)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
# Währung für die UI-Anzeige
BILLING_CURRENCY=EUR

# -----------------------------------------------------------------------------
# Feature-Flags
# -----------------------------------------------------------------------------
# Erlaube Kunden-Galerien ohne Passwort?
FEATURE_PUBLIC_GALLERIES=true
# Optionales KI-Tagging (lokal/Ollama). Standardmäßig aus — wie Picdrop.
FEATURE_AI_TAGGING=false
# Webhooks für Studio-Events
FEATURE_WEBHOOKS=false

# -----------------------------------------------------------------------------
# Observability
# -----------------------------------------------------------------------------
LOG_LEVEL=info
# SENTRY_DSN=
