# Umami — Secrets. Kopieren nach .env (gleiches Verzeichnis) und füllen.
# .env wird NICHT eingecheckt (siehe .gitignore im Repo-Root).

# Passwort der internen Umami-Postgres-DB. Frei wählbar, einmalig setzen.
#   openssl rand -base64 24
UMAMI_DB_PASSWORD=changeme-db-password

# Secret zum Signieren der Dashboard-Login-Sessions. Einmalig erzeugen:
#   openssl rand -base64 32
UMAMI_APP_SECRET=changeme-app-secret
