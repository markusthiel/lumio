# =============================================================================
# Lumio — Caddy Configuration
# =============================================================================
# Konfiguriert drei Site-Adressen mit identischem Verhalten:
#
#   1. LUMIO_HOST         → Haupt-App-Domain (Frontend + API + WS)
#   2. LUMIO_WILDCARD_HOST → Tenant-Subdomains (opt-in, default leer)
#   3. http://             → Catch-All für Custom-Domains der Kunden
#
# Und einen vierten Block für S3:
#   4. LUMIO_S3_HOST       → MinIO / S3
#
# Examples:
#   Lokales Setup (Default-Werte) — LUMIO_HOST unset, Catch-All
#   bedient lokalen Traffic auf Port 80:
#     LUMIO_HOST=                 # nicht setzen
#     LUMIO_S3_HOST=:81
#
#   Produktion mit eigener Domain — LUMIO_HOST ist eine echte
#   Hostname, der Catch-All fängt Custom-Domains der Kunden ab:
#     LUMIO_HOST=studio.lumio-cloud.de
#     LUMIO_S3_HOST=s3.lumio-cloud.de
#
#   Hinter externem Reverse-Proxy (TLS-Termination woanders):
#     LUMIO_HOST=studio.lumio-cloud.de   # Host bleibt nötig für spezifischen Block
#     LUMIO_S3_HOST=s3.lumio-cloud.de
#     externer Proxy: studio.lumio-cloud.de → docker-host:CADDY_HTTP_PORT
#     externer Proxy: s3.lumio-cloud.de     → docker-host:CADDY_HTTP_PORT
#     externer Proxy: foto-kunde.de         → docker-host:CADDY_HTTP_PORT
#     (Custom-Domains werden ohne Env-Änderung vom Catch-All bedient)
#
# Hinweis: die Marketing-Seiten lumio-cloud.de (SaaS-Pitch) und
# lumio-app.de (Open-Source-Pitch) leben in eigenen Repos und werden
# NICHT über diesen Caddy bedient — der externe Reverse-Proxy routet
# diese Domains auf separate Container.
#
# trusted_proxies sorgt dafür, dass X-Forwarded-Proto eines externen
# Reverse-Proxies respektiert wird (siehe Kommentar dort).

{
	admin off
	servers {
		trusted_proxies static private_ranges
	}
}

# Gemeinsamer Block-Inhalt für alle App-Blöcke (Hauptdomain, Wildcard,
# Custom-Domain-Catch-All). Snippets in Caddy v2 werden mit & am Anfang
# referenziert und mit `import` eingebunden.
(lumio_app) {
	reverse_proxy /api/*   api:3001
	reverse_proxy /health  api:3001
	reverse_proxy /ws/*    api:3001

	reverse_proxy frontend:3000

	encode zstd gzip

	header {
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		-Server
	}
}

# -----------------------------------------------------------------------------
# Hauptseite — Frontend + API
# -----------------------------------------------------------------------------
# In Produktion ist LUMIO_HOST=studio.lumio-cloud.de gesetzt → spezifischer
# Block, greift vor dem Catch-All darunter. In lokalem Dev ohne
# LUMIO_HOST entfällt dieser Block (Default 127.0.0.1:9 = unerreichbar,
# Caddy startet ohne Fehler), und der http://-Catch-All bedient alles.
#
# Wichtig: wir können hier NICHT `:80` als Default verwenden — das
# kollidierte mit dem http://-Block darunter, weil beide auf Port 80
# lauschen wollen.
{$LUMIO_HOST:127.0.0.1:9} {
	import lumio_app
}

# -----------------------------------------------------------------------------
# Tenant-Subdomains — <slug>.lumio-cloud.de (opt-in)
# -----------------------------------------------------------------------------
# Konfiguration über LUMIO_WILDCARD_HOST, z.B.:
#   LUMIO_WILDCARD_HOST=*.lumio-cloud.de
#
# Wenn die Wildcard nicht aktiv sein soll, LUMIO_WILDCARD_HOST einfach
# unverändert auf dem Default lassen — der Block fällt dann auf einen
# unerreichbaren Loopback-Port (127.0.0.1:9), Caddy startet ohne Fehler
# und der Block matcht nichts (und holt kein Cert).
#
# Bei aktiver Wildcard: Let's Encrypt verlangt für *.<DOMAIN> eine DNS-01-
# Challenge (HTTP-01 funktioniert nicht für Wildcards). Wir nutzen acme-dns
# als Vermittler — die Credentials liegen in infra/caddy/secrets/acmedns.json
# (NIE in git committen!), CNAME _acme-challenge.<DOMAIN> zeigt auf den
# acme-dns-Server. Setup siehe docs/MULTI_TENANT.md.
{$LUMIO_WILDCARD_HOST:127.0.0.1:9} {
	tls {
		dns acmedns /etc/caddy/secrets/acmedns.json
	}
	import lumio_app
}

# -----------------------------------------------------------------------------
# Marketing-Sites (optional, je nach Deployment)
# -----------------------------------------------------------------------------
# Statische Astro-Sites neben dem App-Stack. Im selben Docker-Netz wie
# Lumio (lumio_net via external: true in deren Compose-Files), Caddy
# proxiert auf die Container-DNS-Namen. Beide Blöcke sind opt-in — falls
# du nur Lumio fährst, kannst du sie löschen oder ignorieren (Caddy
# liefert die Domains dann mangels DNS einfach nicht aus).
#
# Wenn deine Marketing-Sites unter anderen Domains laufen, hier
# entsprechend ändern. Cert wird von Caddy automatisch geholt
# (HTTP-01-Challenge, kein DNS-Setup nötig solange A-Record steht).
lumio-cloud.de {
	reverse_proxy lumio-cloud-de-web-1:4321
	encode zstd gzip
}

lumio-app.de {
	reverse_proxy lumio-app-de-web-1:80
	encode zstd gzip
}

# -----------------------------------------------------------------------------
# Umami — Web-Analytics (stats.lumio-cloud.de)
# -----------------------------------------------------------------------------
# Eigenständiger Stack unter infra/umami (s. dort). Hängt am selben
# lumio_net, daher per Container-DNS 'lumio_umami' erreichbar. Dieser
# spezifische Block greift VOR dem *.lumio-cloud.de-Wildcard-Block (der
# sonst per import lumio_app an die App weiterleiten würde).
#
# Cert via HTTP-01 (wie die Marketing-Blöcke) — A-Record
# stats.lumio-cloud.de muss auf die Server-IP zeigen. Opt-in: läuft kein
# Umami-Stack, liefert Caddy die Domain mangels Container-DNS nicht aus.
stats.lumio-cloud.de {
	reverse_proxy lumio_umami:3000
	encode zstd gzip
}

# -----------------------------------------------------------------------------
# Custom-Domains — Catch-All
# -----------------------------------------------------------------------------
# Greift wenn der Host-Header keiner der spezifischeren Blöcke darüber
# matched. Praktischer Fall: ein Kunde lässt foto-kunde.de auf unsere
# IP zeigen, trägt im Studio den Custom-Domain ein, der externe Caddy
# leitet den Request hierher.
#
# Ohne diesen Block würde Caddy v2 für unbekannte Hosts entweder 404
# senden oder (bei aktivem auto_https) einen 308 nach https:// — was
# in einem externen-Caddy-+-internen-Caddy-Setup einen Endless-Redirect-
# Loop produziert (ERR_TOO_MANY_REDIRECTS im Browser).
#
# Tenant-Auflösung passiert in der API über den Host-Header
# (resolveTenant Schritt "Custom Domain" in apps/api/src/plugins/auth.ts).
# Wenn die Domain in tenants.customDomain steht: alles läuft. Wenn nicht:
# Default-Tenant oder 404 (kein Loop).
#
# `http://` ohne Host-Spec ist ein Catch-All. In Caddy v2 sind benannte
# Hosts spezifischer und werden zuerst gematcht — dieser Block greift
# nur wenn keine andere Site den Request übernehmen kann.
http:// {
	import lumio_app
}

# -----------------------------------------------------------------------------
# S3 / MinIO — separater Hostname
# -----------------------------------------------------------------------------
# MinIO unterstützt kein Path-Präfix-Rewriting (die AWS-V4-Signatur wird
# über den vollen Path inkl. Bucket-Name berechnet). Deshalb läuft S3-Traffic
# auf einem eigenen Hostname und nicht etwa hinter /s3/ am Hauptdomain.
#
# Der Host-Header darf hier NICHT durch Caddy überschrieben werden — die API
# signiert die presigned URL mit dem Host-Header, den der Browser später
# sendet (siehe S3_PUBLIC_URL in apps/api/src/services/storage.ts).
{$LUMIO_S3_HOST::81} {
	reverse_proxy minio:9000 {
		header_up Host {host}
	}

	# CORS für Browser-Uploads (PUT) — MinIO setzt eigene CORS-Header, aber
	# wir lassen den Block hier als Dokumentation für später, falls MinIO
	# CORS aus irgendeinem Grund nicht selbst handhabt.
}
